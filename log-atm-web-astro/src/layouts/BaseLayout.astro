---
import '../styles/global.css';
import {
  useTranslations,
  getLangFromUrl,
  stripLocaleFromPath,
  buildLocaleUrl,
  getAlternateLinks,
  isRTL,
  getHtmlLang,
  getOgLocale,
} from '../i18n/utils';
import { LOCALES, OG_LOCALE, type Locale } from '../i18n/config';
import { SITE } from '../lib/constants';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  /** Locale explícito (preferido cuando la página `[lang]/*.astro` delega vía import). */
  lang?: Locale;
}

const SITE_NAME = 'LOG ATM';
const SITE_URL  = 'https://logatm.com';

// Fuente del locale, en orden de prioridad:
// 1) prop `lang` (cuando la página `[lang]/*.astro` delega y propaga
//    `Astro.params.lang` explícitamente — único método 100% fiable);
// 2) `Astro.currentLocale` (inyectado por el routing i18n cuando aplica);
// 3) `getLangFromUrl(Astro.url)` (fallback al primer segmento del path).
const langProp = (Astro.props as Props).lang;
const currentLang = (langProp ?? (Astro.currentLocale as Locale | undefined) ?? getLangFromUrl(Astro.url)) as Locale;
const t = useTranslations(currentLang);
const DEFAULT_DESC = t('meta.defaultDescription');
const DEFAULT_IMG  = `${SITE_URL}/og-default.svg`;

const htmlLang = getHtmlLang(currentLang);
const dir = isRTL(currentLang) ? 'rtl' : 'ltr';
const cleanPath = stripLocaleFromPath(Astro.url.pathname);

// Canonical/og:url reconstruidos desde `currentLang + cleanPath` para evitar
// la inconsistencia de `Astro.url.pathname` cuando una página `[lang]/foo.astro`
// delega vía `import` en `pages/foo.astro` (en ese caso, Astro.url puede no
// reflejar el segmento de locale en la subruta). Esto asegura URLs localizadas
// y con trailing slash, alineadas con sitemap y hreflang.
const computedCanonicalPath = buildLocaleUrl(currentLang, cleanPath);
const computedCanonical = new URL(computedCanonicalPath, SITE_URL).href;

const {
  title,
  description = DEFAULT_DESC,
  image = DEFAULT_IMG,
  canonical = computedCanonical,
  noindex = false,
} = Astro.props;

const alternates = getAlternateLinks(cleanPath).map((a) => ({
  hreflang: a.hreflang,
  href: new URL(a.href, SITE_URL).href,
}));
const ogLocale = getOgLocale(currentLang);
const ogAlternateLocales = LOCALES.filter((l) => l !== currentLang).map((l) => OG_LOCALE[l]);

const pageTitle = title ? `${title} | ${SITE_NAME}` : `${SITE_NAME} — Logística a tu medida`;

const schemaLocalBusiness = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FreightForwarder',
  name: 'LOG ATM',
  description: DEFAULT_DESC,
  url: SITE_URL,
  telephone: SITE.phone,
  email: SITE.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Av. Pdte Kennedy 5600, Of. 507',
    addressLocality: 'Vitacura',
    addressRegion: 'Región Metropolitana',
    addressCountry: 'CL',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -33.4081,
    longitude: -70.5756,
  },
  sameAs: [
    'https://facebook.com/logatm',
    'https://twitter.com/logatm',
    'https://instagram.com/logatm',
  ],
  areaServed: {
    '@type': 'Country',
    name: 'Chile',
  },
  slogan: 'Logística a tu medida',
});

const schemaWebSite = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_URL}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
});

const breadcrumbSchema = Astro.url.pathname !== '/' ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: SITE_URL,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: title || SITE_NAME,
      item: canonical,
    },
  ],
}) : null;
---

<!doctype html>
<html lang={htmlLang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO primario -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- hreflang alternates (5 locales + x-default) -->
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={image} />
    <meta property="og:site_name"   content={SITE_NAME} />
    <meta property="og:locale"      content={ogLocale} />
    {ogAlternateLocales.map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:site"        content="@logatm" />
    <meta name="twitter:creator"     content="@logatm" />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={image} />

    <meta name="theme-color" content="#4A7BB5" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon"  href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={schemaLocalBusiness} />
    <script type="application/ld+json" set:html={schemaWebSite} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t('a11y.skipLink')}</a>
    <slot />
    <script>
      import '../scripts/scroll-animations';
    </script>
  </body>
</html>
