---
import '../styles/global.css';
import {
  useTranslations,
  isRTL,
  getHtmlLang,
  getOgLocale,
  getAlternateLinks,
  getLangFromUrl,
  buildLocaleUrl,
  stripLocaleFromPath,
  type Locale,
} from '../i18n/utils';
import { DEFAULT_LOCALE } from '../i18n/config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  lang?: Locale;
  currentPath?: string;
}

const SITE_NAME = 'LOG ATM';
const SITE_URL  = 'https://logatm.com';
const DEFAULT_IMG  = `${SITE_URL}/og-default.svg`;

const lang: Locale = Astro.props.lang ?? getLangFromUrl(Astro.url);
const currentPath = Astro.props.currentPath ?? Astro.url.pathname;
const t = useTranslations(lang);

const description = Astro.props.description ?? t('schema.description');
const image = Astro.props.image ?? DEFAULT_IMG;
const noindex = Astro.props.noindex ?? false;
const title = Astro.props.title;

const canonical = Astro.props.canonical ?? new URL(currentPath, SITE_URL).href;
const pageTitle = title
  ? `${title} | ${SITE_NAME}`
  : `${SITE_NAME} — ${t('site.tagline')}`;

const htmlLang = getHtmlLang(lang);
const dir = isRTL(lang) ? 'rtl' : 'ltr';
const ogLocale = getOgLocale(lang);

// Hreflang absolutos
const cleanPath = stripLocaleFromPath(currentPath);
const alternates = getAlternateLinks(currentPath).map((a) => ({
  hreflang: a.hreflang,
  href: new URL(a.href, SITE_URL).href,
}));

const schemaLocalBusiness = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FreightForwarder',
  name: 'LOG ATM',
  description: t('schema.description'),
  url: SITE_URL,
  telephone: '+56942162739',
  email: 'mpazrivera@logatm.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Av. Pdte Kennedy 5600, Of. 507',
    addressLocality: 'Vitacura',
    addressRegion: 'Región Metropolitana',
    addressCountry: 'CL',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -33.4081,
    longitude: -70.5756,
  },
  sameAs: [
    'https://facebook.com/logatm',
    'https://twitter.com/logatm',
    'https://instagram.com/logatm',
  ],
  areaServed: {
    '@type': 'Country',
    name: 'Chile',
  },
  slogan: t('schema.slogan'),
  inLanguage: htmlLang,
});

const schemaWebSite = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  inLanguage: htmlLang,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_URL}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
});

const breadcrumbSchema = cleanPath !== '/' ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: t('schema.breadcrumbHome'),
      item: new URL(buildLocaleUrl(lang, '/'), SITE_URL).href,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: title || SITE_NAME,
      item: canonical,
    },
  ],
}) : null;
// Suppress unused-var warnings for default locale comparison helpers
void DEFAULT_LOCALE;
---

<!doctype html>
<html lang={htmlLang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO primario -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- hreflang -->
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={image} />
    <meta property="og:site_name"   content={SITE_NAME} />
    <meta property="og:locale"      content={ogLocale} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:site"        content="@logatm" />
    <meta name="twitter:creator"     content="@logatm" />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={image} />

    <meta name="theme-color" content="#4A7BB5" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon"  href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={schemaLocalBusiness} />
    <script type="application/ld+json" set:html={schemaWebSite} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t('a11y.skipLink')}</a>
    <slot />
    <script>
      import '../scripts/scroll-animations';
    </script>
  </body>
</html>
