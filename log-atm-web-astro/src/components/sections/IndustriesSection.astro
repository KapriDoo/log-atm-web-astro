---
import { Icon } from 'astro-icon/components';
import { INDUSTRIES } from '../../lib/constants';
---

<section class="industries section" id="industrias" aria-label="Industrias atendidas">
  <div class="container">
    <div class="section-head">
      <div class="section-head__top" data-comment-anchor="10ee8c5d14-div-155-9">
        <div>
          <span class="eyebrow">Industrias</span>
          <h2 class="section-head__title">Sectores que movemos</h2>
        </div>
        <p class="section-head__desc">
          12 industrias con operaciones especializadas, regulaciones particulares
          y rutas optimizadas.
        </p>
      </div>
    </div>

    <div class="industries__grid">
      {INDUSTRIES.map((ind, i) => (
        <a
          class="ind-card ind-card--photo"
          href="/industrias"
          style={`--ind-color: ${ind.color}`}
        >
          <div class="ind-card__media">
            <img src={ind.img} alt={ind.name} loading="lazy" decoding="async" />
          </div>
          <div class="ind-card__top">
            <span class="ind-card__index">{String(i + 1).padStart(2, '0')} · Sector</span>
            <div class="ind-card__icon" aria-hidden="true">
              <Icon name={ind.icon} width={18} height={18} />
            </div>
          </div>
          <div class="ind-card__body">
            <h3 class="ind-card__name">{ind.name}</h3>
            <p class="ind-card__sub">{ind.sub}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
