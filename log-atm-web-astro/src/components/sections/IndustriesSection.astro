---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { INDUSTRIES } from '../../lib/constants';
import { INDUSTRY_IMAGES } from '../../lib/industryImages';
---

<section class="industries" aria-labelledby="industries-heading">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow" data-scroll-animate>Industrias</span>
      <h2 id="industries-heading" class="section-title" data-scroll-animate data-scroll-delay="0.1">Experiencia en tu sector</h2>
    </div>
    <div class="industries__grid" data-scroll-batch>
      {INDUSTRIES.map(({ icon, name, sub, color, image, alt }) => (
        <div class="ind-card" style={`--ind-color:${color}`} data-scroll-animate>
          <div class="ind-card__glow" aria-hidden="true"></div>
          {image && INDUSTRY_IMAGES[image] && (
            <div class="ind-card__image-wrap">
              <Image
                src={INDUSTRY_IMAGES[image]}
                alt={alt || name}
                width={280}
                height={175}
                loading="lazy"
                decoding="async"
                class="ind-card__image"
              />
            </div>
          )}
          {!image && (
            <div class="ind-card__icon-wrap" aria-hidden="true">
              <Icon name={icon} width="28" height="28" class="ind-card__icon" />
            </div>
          )}
          <h3 class="ind-card__name">{name}</h3>
          <p class="ind-card__sub">{sub}</p>
          <span class="ind-card__arrow" aria-hidden="true">→</span>
        </div>
      ))}
    </div>
  </div>
</section>
