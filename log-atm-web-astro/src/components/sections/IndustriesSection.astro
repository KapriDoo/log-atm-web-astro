---
import { INDUSTRIES } from '../../lib/constants';
---

<section class="industries" id="industrias" aria-label="Industrias atendidas">
  <div class="container">
    <div class="industries__head">
      <div class="industries__head-left">
        <span class="eyebrow">Industrias</span>
        <h2 class="industries__title">Sectores que movemos</h2>
      </div>
      <p class="industries__desc">
        12 industrias con operaciones especializadas, regulaciones particulares
        y rutas optimizadas.
      </p>
    </div>

    <div class="industries__grid">
      {INDUSTRIES.map((ind) => (
        <a class="ind-card" href="#industrias" style={`--ind-color: ${ind.color}`}>
          <div class="ind-card__media">
            <img src={ind.img} alt={ind.name} loading="lazy" decoding="async" />
            <div class="ind-card__overlay"></div>
          </div>
          <div class="ind-card__body">
            <h3 class="ind-card__name">{ind.name}</h3>
            <p class="ind-card__sub">{ind.sub}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
