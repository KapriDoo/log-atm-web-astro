---
import { Icon } from 'astro-icon/components';
import { SITE, LIVE_ROUTES } from '../../lib/constants';
import { useTranslations, getLangFromUrl, buildLocaleUrl, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const lang: Locale = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const STAT_KEYS = ['stats.yearsLabel', 'stats.countriesLabel', 'stats.satisfactionLabel', 'stats.dedicatedLabel'] as const;
const STAT_VALUES = ['20+', '70+', '98%', '1:1'];
const quoteHref = buildLocaleUrl(lang, '/cotizar');
---

<header class="hero-b" aria-label={t('hero.eyebrow')}>
  <div class="hero-b__media" aria-hidden="true">
    <img src="/images/services/svc-maritima.jpeg" alt="" fetchpriority="high" />
    <div class="hero-b__overlay"></div>
  </div>

  <div class="container hero-b__inner">
    <div class="hero-b__grid">
      <div class="hero-b__copy">
        <span class="eyebrow eyebrow--light">{t('hero.eyebrow')}</span>
        <h1 class="hero-b__title">
          {t('hero.title1')}<br />
          <span class="hero-b__title-accent">{t('hero.title2')}</span>
        </h1>
        <p class="hero-b__lead" set:html={t('hero.lead')}></p>
        <div class="hero-b__ctas">
          <a class="btn-cta" href={quoteHref}>
            {t('hero.ctaQuote')}
            <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
          </a>
          <a class="btn-ghost-light" href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">
            <Icon name="lucide:message-circle" width={14} height={14} aria-hidden="true" />
            {t('hero.ctaWhatsapp')}
          </a>
        </div>
      </div>

      <aside class="hero-b__live" aria-label={t('hero.liveAria')}>
        <header class="hero-b__live-head">
          <span class="hero-b__live-title">{t('hero.liveTitle')}</span>
          <span class="hero-b__live-pill">{t('hero.livePill')}</span>
        </header>
        <ul class="hero-b__live-rows" role="list">
          {LIVE_ROUTES.map((r) => (
            <li class="hero-b__live-row">
              <span class="hero-b__live-icon" aria-hidden="true">
                <Icon name={r.mode === 'air' ? 'lucide:plane' : 'lucide:ship'} width={14} height={14} />
              </span>
              <span class="hero-b__live-route">
                {r.from} <span class="hero-b__live-arrow">→</span> {r.to}
              </span>
              <span class="hero-b__live-eta">{r.eta}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>

    <div class="hero-b__strip">
      {STAT_KEYS.map((k, i) => (
        <div class="hero-b__strip-item">
          <span class="hero-b__strip-num">{STAT_VALUES[i]}</span>
          <span class="hero-b__strip-label">{t(k)}</span>
        </div>
      ))}
    </div>
  </div>
</header>
