---
import { Icon } from 'astro-icon/components';
import { SITE, LIVE_ROUTES, HERO_STRIP_STATS } from '../../lib/constants';
import { useTranslations, getLangFromUrl, buildLocaleUrl } from '../../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const quoteHref = buildLocaleUrl(currentLang, '/cotizar');
---

<header class="hero hero-b" aria-label={t('a11y.heroAria')}>
  <div class="hero-b__media" aria-hidden="true">
    <img src="/images/services/svc-maritima.jpeg" alt="" fetchpriority="high" />
  </div>

  <div class="container hero-b__inner">
    <div class="hero-b__grid">
      <div>
        <span class="eyebrow eyebrow--light">{t('home.hero.eyebrow')}</span>
        <h1 class="hero-b__title">
          {t('home.hero.title1')}<br />
          <span class="hero-b__title-accent">{t('home.hero.title2')}</span>
        </h1>
        <p class="hero-b__lead" set:html={t('home.hero.leadHtml')} />
        <div class="hero-b__ctas">
          <a class="btn btn--cta" href={quoteHref}>
            {t('home.hero.ctaQuote')}
            <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
          </a>
          <a class="btn btn--ghost-light" href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">
            <Icon name="lucide:message-circle" width={14} height={14} aria-hidden="true" />
            {t('common.whatsapp')}
          </a>
        </div>
      </div>

      <aside class="hero-b__live" aria-label={t('a11y.routesAria')}>
        <div class="hero-b__live-head">
          <span class="hero-b__live-title">{t('home.hero.liveTitle')}</span>
          <span class="hero-b__live-pill">{t('home.hero.livePill')}</span>
        </div>
        <div class="hero-b__live-rows">
          {LIVE_ROUTES.map((r) => (
            <div class="hero-b__live-row">
              <div class="hero-b__live-icon" aria-hidden="true">
                <Icon name={r.mode === 'air' ? 'lucide:plane' : 'lucide:ship'} width={14} height={14} />
              </div>
              <div class="hero-b__live-route">
                {r.from} <span class="hero-b__live-arrow">→</span> {r.to}
              </div>
            </div>
          ))}
        </div>
      </aside>
    </div>

    <div class="hero-b__strip">
      {HERO_STRIP_STATS.map((s) => (
        <div class="hero-b__strip-item">
          <span class="hero-b__strip-num">{s.num}</span>
          <span class="hero-b__strip-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</header>
