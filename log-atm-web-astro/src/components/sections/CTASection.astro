---
import { Icon } from 'astro-icon/components';
import { SITE } from '../../lib/constants';
import { useTranslations, getLangFromUrl, buildLocaleUrl, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const lang: Locale = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const quoteHref = buildLocaleUrl(lang, '/cotizar');
---

<section class="cta-final" id="contacto" aria-label={t('cta.aria')}>
  <div class="container cta-final__inner">
    <div class="cta-final__copy">
      <span class="eyebrow eyebrow--light">{t('cta.eyebrow')}</span>
      <h2 class="cta-final__title">
        {t('cta.title1')}<br />
        <Fragment set:html={t('cta.title2')} />
      </h2>
      <p class="cta-final__lead">{t('cta.lead')}</p>
      <div class="cta-final__ctas">
        <a class="btn-cta" href={quoteHref}>
          {t('cta.ctaQuote')}
          <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
        </a>
        <a class="btn-ghost-light" href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">
          <Icon name="lucide:message-circle" width={16} height={16} aria-hidden="true" />
          {t('cta.ctaWhatsapp')}
        </a>
      </div>
    </div>

    <form class="cta-final__form" id="cta-form" novalidate data-quote-href={quoteHref}>
      <p class="cta-final__form-title">{t('cta.formTitle')}</p>

      <div class="cta-final__row">
        <div class="cta-final__field">
          <label class="cta-final__label" for="cta-mode">{t('cta.formMode')}</label>
          <select class="cta-final__select" id="cta-mode" name="mode">
            <option>{t('cta.modeOptions.fcl')}</option>
            <option>{t('cta.modeOptions.lcl')}</option>
            <option>{t('cta.modeOptions.air')}</option>
            <option>{t('cta.modeOptions.courier')}</option>
          </select>
        </div>
        <div class="cta-final__field">
          <label class="cta-final__label" for="cta-origin">{t('cta.formOrigin')}</label>
          <select class="cta-final__select" id="cta-origin" name="origin">
            <option>Shanghai, CN</option>
            <option>Miami, US</option>
            <option>Rotterdam, NL</option>
            <option>Dubai, AE</option>
          </select>
        </div>
      </div>

      <div class="cta-final__row">
        <div class="cta-final__field">
          <label class="cta-final__label" for="cta-dest">{t('cta.formDest')}</label>
          <select class="cta-final__select" id="cta-dest" name="dest">
            <option>Santiago, CL</option>
            <option>San Antonio, CL</option>
            <option>Iquique, CL</option>
          </select>
        </div>
        <div class="cta-final__field">
          <label class="cta-final__label" for="cta-vol">{t('cta.formVolume')}</label>
          <select class="cta-final__select" id="cta-vol" name="volume">
            <option>{t('cta.volumeOptions.small')}</option>
            <option>{t('cta.volumeOptions.medium')}</option>
            <option>{t('cta.volumeOptions.container20')}</option>
            <option>{t('cta.volumeOptions.container40')}</option>
          </select>
        </div>
      </div>

      <button class="cta-final__btn" type="submit">
        {t('cta.formSubmit')}
        <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
      </button>

      <p class="cta-final__alt">
        {t('cta.formAlt')} <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('cta-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const params = new URLSearchParams();
    data.forEach((v, k) => params.set(k, String(v)));
    const target = form.dataset.quoteHref || '/cotizar';
    window.location.href = `${target}?${params.toString()}`;
  });
</script>
