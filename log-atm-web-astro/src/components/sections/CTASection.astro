---
import { Icon } from 'astro-icon/components';
import { SITE } from '../../lib/constants';
---

<section class="cta-final" id="contacto" aria-label="Cotización rápida">
  <div class="container cta-final__inner">
    <div class="cta-final__copy">
      <span class="eyebrow eyebrow--light">Empieza hoy</span>
      <h2 class="cta-final__title">
        Tu próximo envío,<br />
        con <em>visibilidad total</em>.
      </h2>
      <p class="cta-final__lead">
        Cotiza en menos de 24 horas con un ejecutivo dedicado.
        Sin intermediarios, sin sorpresas.
      </p>
      <div class="cta-final__ctas">
        <a class="btn-cta" href="/cotizar">
          Cotiza ahora
          <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
        </a>
        <a class="btn-ghost-light" href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">
          <Icon name="lucide:message-circle" width={16} height={16} aria-hidden="true" />
          WhatsApp
        </a>
      </div>
    </div>

    <form class="cta-final__form" id="cta-form" novalidate>
      <p class="cta-final__form-title">Cotización rápida · 30 seg</p>

      <div class="cta-final__row">
        <div class="cta-final__field">
          <label class="cta-final__label" for="cta-mode">Modalidad</label>
          <select class="cta-final__select" id="cta-mode" name="mode">
            <option>Marítimo · FCL</option>
            <option>Marítimo · LCL</option>
            <option>Aéreo</option>
            <option>Courier</option>
          </select>
        </div>
        <div class="cta-final__field">
          <label class="cta-final__label" for="cta-origin">Origen</label>
          <select class="cta-final__select" id="cta-origin" name="origin">
            <option>Shanghai, CN</option>
            <option>Miami, US</option>
            <option>Rotterdam, NL</option>
            <option>Dubai, AE</option>
          </select>
        </div>
      </div>

      <div class="cta-final__row">
        <div class="cta-final__field">
          <label class="cta-final__label" for="cta-dest">Destino</label>
          <select class="cta-final__select" id="cta-dest" name="dest">
            <option>Santiago, CL</option>
            <option>San Antonio, CL</option>
            <option>Iquique, CL</option>
          </select>
        </div>
        <div class="cta-final__field">
          <label class="cta-final__label" for="cta-vol">Volumen</label>
          <select class="cta-final__select" id="cta-vol" name="volume">
            <option>1 CBM o menos</option>
            <option>1 – 15 CBM</option>
            <option>1 contenedor 20'</option>
            <option>1 contenedor 40'</option>
          </select>
        </div>
      </div>

      <button class="cta-final__btn" type="submit">
        Obtener cotización
        <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
      </button>

      <p class="cta-final__alt">
        O escríbenos a <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('cta-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const params = new URLSearchParams();
    data.forEach((v, k) => params.set(k, String(v)));
    window.location.href = `/cotizar?${params.toString()}`;
  });
</script>
