---
import { Icon } from 'astro-icon/components';
import { WHY_ITEMS } from '../../lib/constants';
import { useTranslations, getLangFromUrl, tList } from '../../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

type WhyCopy = { title: string; desc: string; sub: string };
const whyCopy = tList<WhyCopy>(currentLang, 'home.why.items');
const whyItems = WHY_ITEMS.map((w, i) => ({
  ...w,
  ...(whyCopy[i] ?? { title: w.title, desc: w.desc, sub: w.sub }),
}));
---

<section class="why section" id="why" aria-label={t('a11y.whyAria')}>
  <div class="container">
    <div class="section-head">
      <div class="section-head__top">
        <div>
          <span class="eyebrow">{t('home.why.eyebrow')}</span>
          <h2 class="section-head__title">{t('home.why.title')}</h2>
        </div>
        <p class="section-head__desc">{t('home.why.desc')}</p>
      </div>
    </div>

    <div class="why__grid">
      <div class="why__video" data-scroll-animate data-scroll-type="fade-in">
        <video
          class="why__video-el"
          poster="/images/services/svc-maritima.jpeg"
          muted
          loop
          playsinline
          preload="metadata"
          aria-label={t('a11y.videoAria')}
        >
          <source src="/videos/log-atm-intro.mp4" type="video/mp4" />
        </video>

        <button
          type="button"
          class="why__video-toggle"
          id="why-video-toggle"
          aria-label={t('a11y.playVideo')}
          aria-pressed="false"
          data-label-play={t('a11y.playVideo')}
          data-label-pause={t('a11y.pauseVideo')}
        >
          <span class="why__video-toggle-icon" aria-hidden="true" data-state="paused">▶</span>
        </button>

        <div class="why__video-logo" aria-hidden="true">
          <img src="/logo.png" alt="" />
          <span class="why__video-logo-tag">{t('home.why.videoLogoTag')}</span>
        </div>

        <div class="why__video-caption">
          <span class="why__video-eyebrow">{t('home.why.videoEyebrow')}</span>
          <span class="why__video-title">{t('home.why.videoTitle')}</span>
        </div>
      </div>

      <div class="why__items" data-scroll-batch>
        {whyItems.map((w) => (
          <div class="why-card" data-scroll-animate data-scroll-type="fade-left">
            <div class="why-card__icon" aria-hidden="true">
              <Icon name={w.icon} width={22} height={22} />
            </div>
            <div>
              <h3 class="why-card__title">{w.title}</h3>
              <p class="why-card__desc">{w.desc}</p>
            </div>
            <div class="why-card__metric">
              {w.metric}<small>{w.sub}</small>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const video  = document.querySelector<HTMLVideoElement>('.why__video-el');
  const logo   = document.querySelector<HTMLElement>('.why__video-logo');
  const toggle = document.getElementById('why-video-toggle') as HTMLButtonElement | null;
  const icon   = toggle?.querySelector<HTMLElement>('.why__video-toggle-icon') ?? null;

  if (video && logo && toggle && icon) {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const update = () => {
      if (!video.duration || !isFinite(video.duration)) return;
      const remain = video.duration - video.currentTime;
      logo.classList.toggle('is-visible', remain <= 1.0 && video.currentTime > 0.2);
    };

    const syncToggle = () => {
      const playing = !video.paused && !video.ended;
      toggle.setAttribute('aria-pressed', String(playing));
      toggle.setAttribute('aria-label', playing ? (toggle.dataset.labelPause ?? 'Pausar video') : (toggle.dataset.labelPlay ?? 'Reproducir video'));
      icon.textContent = playing ? '❚❚' : '▶';
      icon.dataset.state = playing ? 'playing' : 'paused';
    };

    toggle.addEventListener('click', () => {
      if (video.paused) video.play().catch(() => { /* noop */ });
      else video.pause();
    });

    video.addEventListener('timeupdate', update);
    video.addEventListener('seeked', () => {
      if (video.currentTime < 0.2) logo.classList.remove('is-visible');
    });
    video.addEventListener('play', syncToggle);
    video.addEventListener('pause', syncToggle);
    video.addEventListener('ended', syncToggle);

    // Autoplay sólo si el usuario no pidió reducir movimiento (WCAG 2.2.2).
    if (!reduceMotion) {
      video.play().catch(() => { /* noop — Safari iOS estricto */ });
    }
    syncToggle();
  }
</script>

<style>
  .why__video-toggle {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    z-index: 3;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 0.4);
    background: rgb(0 0 0 / 0.55);
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: background 150ms, transform 150ms;
  }
  .why__video-toggle:hover { background: rgb(0 0 0 / 0.75); }
  .why__video-toggle:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .why__video-toggle-icon {
    font-size: 0.875rem;
    line-height: 1;
  }
</style>
