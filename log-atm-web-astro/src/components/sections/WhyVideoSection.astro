---
import { Icon } from 'astro-icon/components';
import { WHY_ITEMS } from '../../lib/constants';
---

<section class="why section" id="why" aria-label="Por qué LOG ATM">
  <div class="container">
    <div class="section-head">
      <div class="section-head__top">
        <div>
          <span class="eyebrow">Por qué LOG ATM</span>
          <h2 class="section-head__title">El operador que opera contigo</h2>
        </div>
        <p class="section-head__desc">
          Somos un partner logístico, no un proveedor más. Conocemos tu negocio
          y diseñamos la operación a tu medida.
        </p>
      </div>
    </div>

    <div class="why__grid">
      <div class="why__video">
        <video
          class="why__video-el"
          poster="/images/services/svc-maritima.jpeg"
          muted
          autoplay
          loop
          playsinline
          preload="auto"
        >
          <source src="/videos/log-atm-intro.mp4" type="video/mp4" />
        </video>

        <div class="why__video-logo" aria-hidden="true">
          <img src="/logo.png" alt="LOG ATM" />
          <span class="why__video-logo-tag">Logística a tu medida</span>
        </div>

        <div class="why__video-caption">
          <span class="why__video-eyebrow">Conoce LOG ATM</span>
          <span class="why__video-title">2 minutos para entender cómo trabajamos</span>
        </div>
      </div>

      <div class="why__items">
        {WHY_ITEMS.map((w) => (
          <div class="why-card">
            <div class="why-card__icon" aria-hidden="true">
              <Icon name={w.icon} width={22} height={22} />
            </div>
            <div>
              <h3 class="why-card__title">{w.title}</h3>
              <p class="why-card__desc">{w.desc}</p>
            </div>
            <div class="why-card__metric">
              {w.metric}<small>{w.sub}</small>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const video = document.querySelector<HTMLVideoElement>('.why__video-el');
  const logo  = document.querySelector<HTMLElement>('.why__video-logo');
  if (video && logo) {
    const update = () => {
      if (!video.duration || !isFinite(video.duration)) return;
      const remain = video.duration - video.currentTime;
      logo.classList.toggle('is-visible', remain <= 1.0 && video.currentTime > 0.2);
    };
    video.addEventListener('timeupdate', update);
    video.addEventListener('seeked', () => {
      if (video.currentTime < 0.2) logo.classList.remove('is-visible');
    });
    // muted autoplay should be allowed; ignore failures (Safari iOS strict mode)
    video.play().catch(() => { /* noop */ });
  }
</script>
