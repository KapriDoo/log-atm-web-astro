---
import { Icon } from 'astro-icon/components';
import { useTranslations, getLangFromUrl, type Locale } from '../../i18n/utils';

interface Props { lang?: Locale; }
const lang: Locale = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const ITEMS = [
  { slug: 'executive', icon: 'lucide:user-round-check' },
  { slug: 'network',   icon: 'lucide:globe-2' },
  { slug: 'support',   icon: 'lucide:clock' },
  { slug: 'customs',   icon: 'lucide:shield-check' },
] as const;
---

<section class="why" id="why" aria-label={t('why.aria')}>
  <div class="container">
    <div class="why__head">
      <div class="why__head-left">
        <span class="eyebrow">{t('why.eyebrow')}</span>
        <h2 class="why__title">{t('why.title')}</h2>
      </div>
      <p class="why__desc">{t('why.desc')}</p>
    </div>

    <div class="why__grid">
      <div class="why__video">
        <video
          class="why__video-el"
          poster="/images/services/svc-maritima.jpeg"
          muted
          autoplay
          loop
          playsinline
          preload="auto"
        >
          <source src="/video/intro.mp4" type="video/mp4" />
        </video>

        <div class="why__video-logo" aria-hidden="true">
          <img src="/logo.png" alt="" />
          <span class="why__video-logo-tag">{t('why.videoLogoTag')}</span>
        </div>

        <div class="why__video-caption">
          <span class="why__video-eyebrow">{t('why.videoEyebrow')}</span>
          <span class="why__video-title">{t('why.videoTitle')}</span>
        </div>
      </div>

      <div class="why__items">
        {ITEMS.map((w) => (
          <article class="why-card">
            <span class="why-card__icon" aria-hidden="true">
              <Icon name={w.icon} width={22} height={22} />
            </span>
            <div class="why-card__body">
              <h3 class="why-card__title">{t(`why.items.${w.slug}.title`)}</h3>
              <p class="why-card__desc">{t(`why.items.${w.slug}.desc`)}</p>
            </div>
            <div class="why-card__metric">
              <span class="why-card__metric-value">{t(`why.items.${w.slug}.metric`)}</span>
              <span class="why-card__metric-sub">{t(`why.items.${w.slug}.sub`)}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const video = document.querySelector<HTMLVideoElement>('.why__video-el');
  const logo  = document.querySelector<HTMLElement>('.why__video-logo');
  if (video && logo) {
    const update = () => {
      if (!video.duration || !isFinite(video.duration)) return;
      const remain = video.duration - video.currentTime;
      logo.classList.toggle('is-visible', remain <= 1.0 && video.currentTime > 0.2);
    };
    video.addEventListener('timeupdate', update);
    video.addEventListener('seeked', () => {
      if (video.currentTime < 0.2) logo.classList.remove('is-visible');
    });
    video.play().catch(() => { /* autoplay blocked: noop */ });
  }
</script>
