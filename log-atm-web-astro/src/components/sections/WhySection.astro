---
import { Icon } from 'astro-icon/components';
import { WHY_ITEMS } from '../../lib/constants';
---

<section class="why" aria-labelledby="why-heading">
  <div class="container why__inner">
    <div class="why__visual">
      <div class="why__img-wrap">
        <div class="why__video-wrap">
          <video
            class="why__video"
            src="/videos/hero-port.mp4"
            muted
            autoplay
            playsinline
            aria-label="Camión en ruta costera — operación logística LOG ATM"
          ></video>
          <div class="why__logo-overlay" aria-hidden="true">
            <img src="/logo.svg" alt="" width="180" height="198" />
          </div>
        </div>
        <div class="why__badge">
          <span class="why__badge-icon">🇨🇱</span>
          <div>
            <p class="why__badge-title">Empresa chilena</p>
            <p class="why__badge-sub">con red global</p>
          </div>
        </div>
      </div>
    </div>

    <div class="why__content">
      <span class="eyebrow">Por qué LOG ATM</span>
      <h2 id="why-heading" class="section-title">
        Personas. Confianza.<br/>Resultados.
      </h2>
      <p class="section-lead why__lead">
        No somos una multinacional anónima. Somos un equipo chileno con
        conexiones globales y el compromiso de tratarte como nuestro único cliente.
      </p>

      <ul class="why__list" role="list">
        {WHY_ITEMS.map(({ icon, title, desc, anim }) => (
          <li class="why__item">
            <div class:list={['why__item-icon', anim && `why__item-icon--${anim}`]} aria-hidden="true">
              <Icon name={icon} width="22" height="22" />
            </div>
            <div>
              <strong class="why__item-title">{title}</strong>
              <p class="why__item-desc">{desc}</p>
            </div>
          </li>
        ))}
      </ul>

      <a href="#nosotros" class="why__btn">Conoce al equipo</a>
    </div>
  </div>
</section>

<script>
  // Video loop con pausa para mostrar el logo al final
  const LOGO_DISPLAY_MS = 2500;
  let cleanupWhyVideo: (() => void) | null = null;

  function initWhyVideo() {
    // Limpiar instancia anterior (protege contra view transitions)
    cleanupWhyVideo?.();

    const video = document.querySelector<HTMLVideoElement>('.why__video');
    const overlay = document.querySelector<HTMLElement>('.why__logo-overlay');
    if (!video || !overlay) return;

    // Respetar prefers-reduced-motion
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    let timerId: ReturnType<typeof setTimeout> | null = null;

    function onVideoEnded() {
      overlay!.classList.add('is-visible');
      timerId = setTimeout(() => {
        overlay!.classList.remove('is-visible');
        video!.play();
        timerId = null;
      }, LOGO_DISPLAY_MS);
    }

    video.addEventListener('ended', onVideoEnded);

    // Función de cleanup para evitar memory leaks
    cleanupWhyVideo = () => {
      video.removeEventListener('ended', onVideoEnded);
      if (timerId !== null) {
        clearTimeout(timerId);
        timerId = null;
      }
      cleanupWhyVideo = null;
    };
  }

  // Ejecutar cuando el DOM esté listo (compatible con Astro view transitions)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWhyVideo);
  } else {
    initWhyVideo();
  }
  document.addEventListener('astro:after-swap', initWhyVideo);
</script>
