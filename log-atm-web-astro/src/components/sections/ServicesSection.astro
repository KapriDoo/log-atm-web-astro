---
import { Icon } from 'astro-icon/components';
import { SERVICES } from '../../lib/constants';
---

<section class="services" id="servicios" aria-label="Servicios LOG ATM">
  <div class="container">
    <div class="services__head">
      <div class="services__head-left">
        <span class="eyebrow">Qué hacemos</span>
        <h2 class="services__title">Soluciones para cada necesidad</h2>
      </div>
      <p class="services__desc">
        Desde el despacho urgente hasta la consultoría de supply chain completa.
        Cada cuenta tiene un ejecutivo dedicado que diseña la ruta a tu medida.
      </p>
    </div>

    <div class="services__grid">
      {SERVICES.map((s) => (
        <a class:list={[`svc-card`, `svc-card--${s.size}`]} href={s.href}>
          <div class="svc-card__media">
            <img src={s.img} alt={s.title} loading="lazy" decoding="async" />
            <div class="svc-card__overlay"></div>
          </div>
          <span class:list={['svc-card__tag', { 'svc-card__tag--cta': s.isCta }]}>{s.tag}</span>
          <span class="svc-card__icon-pill" aria-hidden="true">
            <Icon name={s.icon} width={18} height={18} />
          </span>
          <div class="svc-card__body">
            <span class="svc-card__num">{s.n} · Servicio</span>
            <h3 class="svc-card__title">{s.title}</h3>
            <p class="svc-card__desc">{s.desc}</p>
            <span class="svc-card__cta">
              Conocer más
              <Icon name="lucide:arrow-right" width={14} height={14} aria-hidden="true" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
