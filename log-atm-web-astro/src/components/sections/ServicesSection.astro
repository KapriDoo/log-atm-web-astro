---
import { Picture } from 'astro:assets';
import Icon from "../ui/Icon.astro";
import { SERVICES } from '../../lib/constants';
import { useTranslations, getLangFromUrl, buildLocaleUrl, tList } from '../../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const servicesHref = buildLocaleUrl(currentLang, '/servicios');

type ServiceCopy = { title: string; desc: string; tag: string };
const serviceCopies = tList<ServiceCopy>(currentLang, 'servicios.list');
const localizedServices = SERVICES.map((s, i) => ({
  ...s,
  ...(serviceCopies[i] ?? { title: s.title, desc: s.desc, tag: s.tag }),
}));

// Home muestra 6 servicios principales en bento (paridad target):
// fila 1: Marítima (wide) izq + Aérea (feature, ocupa 2 filas) der
// fila 2: Aduana + Almacenaje + Consultoría (std, 3 chicos a la izq)
// fila 3: Courier (wide)
const FEATURED = [
  localizedServices[1], // 02 Carga Marítima (wide)
  localizedServices[0], // 01 Carga Aérea     (feature, spans 2 filas)
  localizedServices[2], // 03 Aduana          (std)
  localizedServices[3], // 04 Almacenaje      (std)
  localizedServices[4], // 05 Consultoría     (std)
  localizedServices[5], // 06 Courier         (wide)
];
const TOTAL = SERVICES.length;
---

<section class="services section" id="servicios" aria-label={t('a11y.servicesAria')}>
  <div class="container">
    <div class="section-head">
      <div class="section-head__top">
        <div>
          <span class="eyebrow">{t('home.services.eyebrow')}</span>
          <h2 class="section-head__title">{t('home.services.title')}</h2>
        </div>
        <p class="section-head__desc">{t('home.services.desc')}</p>
      </div>
    </div>

    <div class="services__grid" data-scroll-batch>
      {FEATURED.map((s) => {
        const isLink = Boolean(s.href);
        const CardTag = isLink ? 'a' : 'div';
        return (
          <CardTag
            class:list={['svc-card', `svc-card--${s.size}`, { 'svc-card--static': !isLink }]}
            href={isLink ? s.href : undefined}
            data-scroll-animate
            data-scroll-type="fade-up"
          >
            <div class="svc-card__media">
              <Picture src={s.img} formats={['avif', 'webp']} alt="" quality={80} />
            </div>
            <span class:list={['svc-card__tag', { 'svc-card__tag--cta': s.isCta }]}>{s.tag}</span>
            <div class="svc-card__icon-pill" aria-hidden="true">
              <Icon name={s.icon} width={18} height={18} />
            </div>
            <div class="svc-card__body">
              <div class="svc-card__num">{s.n} · {t('home.services.numPrefix')}</div>
              <h3 class="svc-card__title">{s.title}</h3>
              <p class="svc-card__desc">{s.desc}</p>
            </div>
          </CardTag>
        );
      })}
    </div>

    <div class="services__all">
      <a class="btn btn--brand" href={servicesHref}>
        {t('common.viewAllServices', { count: TOTAL })}
        <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
      </a>
    </div>
  </div>
</section>
