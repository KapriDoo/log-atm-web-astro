---
import { NAV_LINKS, SITE } from '../../lib/constants';
const currentPath = Astro.url.pathname;

function hasChildren(link: typeof NAV_LINKS[number]): link is Extract<typeof NAV_LINKS[number], { children: any }> {
  return 'children' in link;
}
---

<header class="navbar" id="navbar" role="banner">
  <div class="navbar__inner">
    <a href="/" class="navbar__brand" aria-label="LOG ATM — Inicio">
      <img class="navbar__brand-logo" src="/logo.png" alt="" width="38" height="38" loading="eager" fetchpriority="high" />
      <span class="navbar__brand-text">
        <span class="navbar__brand-name">LOG ATM</span>
        <span class="navbar__brand-sub">LOGÍSTICA A TU MEDIDA</span>
      </span>
    </a>

    <nav class="navbar__nav" aria-label="Navegación principal">
      <ul class="navbar__links" role="list">
        {NAV_LINKS.map((link, idx) => (
          hasChildren(link) ? (
            <li class="navbar__item navbar__item--dropdown">
              <button
                type="button"
                class="navbar__link navbar__link--trigger"
                id={`nav-trigger-${idx}`}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {link.label}
                <svg class="navbar__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </button>
              <ul class="dropdown" role="menu" aria-labelledby={`nav-trigger-${idx}`}>
                {link.children.map((child) => (
                  <li role="none">
                    <a href={child.href} class="dropdown__link" role="menuitem">
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a
                href={link.href}
                class:list={['navbar__link', { 'is-active': currentPath.startsWith(link.href) }]}
                aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
              >{link.label}</a>
            </li>
          )
        ))}
      </ul>
    </nav>

    <div class="navbar__actions">
      <a href="#cotizar"  class="navbar__cta">Cotiza ahora</a>
    </div>

    <!-- Hamburger -->
    <button class="navbar__burger" id="burger" aria-label="Abrir menú" aria-expanded="false" aria-controls="drawer">
      <span class="burger__bar"></span>
      <span class="burger__bar"></span>
      <span class="burger__bar"></span>
    </button>
  </div>
</header>

<!-- Drawer overlay (mobile) -->
<div class="drawer" id="drawer" aria-hidden="true">
  <div class="drawer__backdrop" id="drawer-backdrop"></div>
  <nav class="drawer__panel" role="dialog" aria-modal="true" aria-label="Menú de navegación">
    <div class="drawer__header">
      <a href="/" class="drawer__logo" aria-label="LOG ATM — Inicio">
        <img src="/logo.png" alt="" width="38" height="38" />
        <span>
          <span class="navbar__brand-name">LOG ATM</span>
          <span class="navbar__brand-sub">LOGÍSTICA A TU MEDIDA</span>
        </span>
      </a>
      <button class="drawer__close" id="drawer-close" aria-label="Cerrar menú">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <ul class="drawer__links" role="list">
      {NAV_LINKS.map((link) => (
        hasChildren(link) ? (
          <li class="drawer__group">
            <span class="drawer__group-label">{link.label}</span>
            <ul class="drawer__group-links" role="list">
              {link.children.map((child) => (
                <li>
                  <a href={child.href} class="drawer__link">{child.label}</a>
                </li>
              ))}
            </ul>
          </li>
        ) : (
          <li>
            <a
              href={link.href}
              class:list={['drawer__link', { 'is-active': currentPath.startsWith(link.href) }]}
              aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            >{link.label}</a>
          </li>
        )
      ))}
    </ul>

    <div class="drawer__ctas">
      <a href="#cotizar"  class="drawer__cta">Cotiza ahora →</a>
    </div>

    <div class="drawer__contact">
      <a href={`tel:${SITE.phone}`}>{SITE.phone}</a>
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
    </div>
  </nav>
</div>

<style>
  /* ─── Navbar ─────────────────────────────────────────────── */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-text-inverse) 94%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow 200ms ease;
  }
  .navbar.is-scrolled {
    box-shadow: 0 2px 24px color-mix(in srgb, var(--color-primary-500) 10%, transparent);
  }

  .navbar__inner {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
    height: 72px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
  }
  .navbar__brand-logo {
    width: 38px;
    height: 38px;
    object-fit: contain;
  }
  .navbar__brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
    line-height: 1;
  }
  .navbar__brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.0625rem;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }
  .navbar__brand-sub {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .navbar__nav { flex: 1; }
  .navbar__links {
    display: flex;
    list-style: none;
    margin: 0; padding: 0;
    gap: 0.125rem;
  }

  .navbar__link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-neutral-600);
    border-radius: var(--radius-sm);
    transition: color 150ms, background 150ms;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }
  .navbar__link:hover,
  .navbar__link.is-active {
    color: var(--color-brand);
    background: var(--color-primary-50);
  }

  .navbar__chevron {
    transition: transform 200ms ease;
  }
  .navbar__item--dropdown.is-open .navbar__chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .navbar__item--dropdown {
    position: relative;
  }

  .dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 240px;
    max-height: 70vh;
    overflow-y: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 12px 40px color-mix(in srgb, var(--color-primary-900) 12%, transparent);
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 180ms ease, transform 180ms ease, visibility 180ms ease;
    z-index: 110;
    list-style: none;
    margin: 0;
  }

  .navbar__item--dropdown.is-open .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown__link {
    display: block;
    padding: 0.625rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-neutral-700);
    border-radius: var(--radius-sm);
    transition: background 150ms, color 150ms;
    white-space: nowrap;
  }
  .dropdown__link:hover,
  .dropdown__link:focus {
    background: var(--color-primary-50);
    color: var(--color-brand);
    outline: none;
  }

  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .navbar__track {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-neutral-600);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--color-border);
    transition: border-color 150ms, color 150ms;
    white-space: nowrap;
  }
  .navbar__track:hover {
    border-color: var(--color-brand);
    color: var(--color-brand);
  }

  .navbar__cta {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-inverse);
    background: var(--color-brand);
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-pill);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--color-brand) 28%, transparent);
    transition: background 150ms, transform 100ms, box-shadow 150ms;
    white-space: nowrap;
  }
  .navbar__cta:hover {
    background: var(--color-primary-700);
    transform: translateY(-1px);
    box-shadow: 0 4px 18px color-mix(in srgb, var(--color-brand) 40%, transparent);
  }

  /* Hamburger */
  .navbar__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
    width: 44px;
    height: 44px;
  }
  .burger__bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-neutral-800);
    border-radius: var(--radius-sm);
    transition: transform 250ms ease, opacity 250ms ease;
    transform-origin: center;
  }
  .navbar__burger[aria-expanded="true"] .burger__bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .navbar__burger[aria-expanded="true"] .burger__bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .navbar__burger[aria-expanded="true"] .burger__bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ─── Drawer ─────────────────────────────────────────────── */
  .drawer {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
  }
  .drawer[aria-hidden="false"] { display: block; }

  .drawer__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-primary-900) 55%, transparent);
    backdrop-filter: blur(4px);
    animation: fadeIn 200ms ease forwards;
  }

  .drawer__panel {
    position: absolute;
    top: 0; right: 0;
    width: min(320px, 88vw);
    height: 100dvh;
    background: var(--color-surface);
    box-shadow: -8px 0 48px color-mix(in srgb, var(--color-text-inverse-alt) 18%, transparent);
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    gap: 1rem;
    animation: slideIn 250ms cubic-bezier(0.32, 0.72, 0, 1) forwards;
    overflow-y: auto;
  }

  .drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .drawer__logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .drawer__logo img { width: 38px; height: 38px; object-fit: contain; }
  .drawer__logo > span { display: flex; flex-direction: column; gap: 0.125rem; line-height: 1; }

  .drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.625rem;
    border-radius: var(--radius-sm);
    color: var(--color-neutral-600);
    transition: background 150ms, color 150ms;
  }
  .drawer__close:hover { background: var(--color-neutral-100); color: var(--color-neutral-900); }

  .drawer__links {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
  }

  .drawer__link {
    display: block;
    padding: 0.875rem 1rem;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-neutral-700);
    border-radius: var(--radius-sm);
    transition: background 150ms, color 150ms;
  }
  .drawer__link:hover,
  .drawer__link.is-active {
    background: var(--color-primary-50);
    color: var(--color-brand);
  }

  .drawer__group {
    margin-bottom: 0.5rem;
  }

  .drawer__group-label {
    display: block;
    padding: 0.75rem 1rem 0.375rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-neutral-500);
  }

  .drawer__group-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding-left: 0.5rem;
  }

  .drawer__group-links .drawer__link {
    font-size: 0.9375rem;
    padding: 0.625rem 1rem;
  }

  .drawer__ctas {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .drawer__track {
    text-align: center;
    padding: 0.875rem;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--color-primary-300);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-brand);
    transition: border-color 150ms, background 150ms;
  }
  .drawer__track:hover { background: var(--color-primary-50); }

  .drawer__cta {
    text-align: center;
    padding: 0.875rem;
    border-radius: var(--radius-pill);
    background: var(--color-brand);
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-text-inverse);
    box-shadow: 0 3px 14px color-mix(in srgb, var(--color-brand) 32%, transparent);
    transition: background 150ms;
  }
  .drawer__cta:hover { background: var(--color-primary-700); }

  .drawer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-top: 0.75rem;
  }
  .drawer__contact a {
    font-size: 0.8125rem;
    color: var(--color-neutral-500);
    transition: color 150ms;
  }
  .drawer__contact a:hover { color: var(--color-brand); }

  /* ─── Animations ────────────────────────────────────────── */
  @keyframes fadeIn  { from { opacity: 0 } to { opacity: 1 } }
  @keyframes slideIn { from { transform: translateX(100%) } to { transform: translateX(0) } }

  /* ─── Responsive ─────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .navbar__nav, .navbar__actions { display: none; }
    .navbar__burger { display: flex; }
  }
  @media (max-width: 479px) {
    .navbar__brand-text { display: none; }
    .navbar__inner { height: 60px; padding-inline: 1rem; }
  }
</style>

<script>
  const burger   = document.getElementById('burger')!;
  const drawer   = document.getElementById('drawer')!;
  const backdrop = document.getElementById('drawer-backdrop')!;
  const closeBtn = document.getElementById('drawer-close')!;
  const navbar   = document.getElementById('navbar')!;

  let lastFocusedElement: HTMLElement | null = null;

  function getFocusableElements() {
    return Array.from(
      drawer.querySelectorAll<HTMLElement>('a[href], button, [tabindex]:not([tabindex="-1"])')
    );
  }

  function trapFocus(e: KeyboardEvent) {
    if (e.key !== 'Tab') return;
    const focusable = getFocusableElements();
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];

    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  function openDrawer() {
    lastFocusedElement = document.activeElement as HTMLElement;
    drawer.setAttribute('aria-hidden', 'false');
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    // Transferir foco al primer elemento focusable del drawer
    const focusable = getFocusableElements();
    if (focusable.length > 0) focusable[0].focus();
    drawer.addEventListener('keydown', trapFocus);
  }

  function closeDrawer() {
    drawer.removeEventListener('keydown', trapFocus);
    drawer.setAttribute('aria-hidden', 'true');
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    // Devolver foco al elemento que abrió el drawer
    if (lastFocusedElement) lastFocusedElement.focus();
  }

  burger.addEventListener('click', openDrawer);
  closeBtn.addEventListener('click', closeDrawer);
  backdrop.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') closeDrawer();
  });

  // ─── Dropdown handling ────────────────────────────────────
  const dropdownItems = document.querySelectorAll<HTMLElement>('.navbar__item--dropdown');

  function closeAllDropdowns() {
    dropdownItems.forEach(item => {
      item.classList.remove('is-open');
      const trigger = item.querySelector('.navbar__link--trigger');
      if (trigger) trigger.setAttribute('aria-expanded', 'false');
    });
  }

  dropdownItems.forEach(item => {
    const trigger = item.querySelector('.navbar__link--trigger') as HTMLButtonElement;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = item.classList.contains('is-open');
      closeAllDropdowns();
      if (!isOpen) {
        item.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Click outside closes dropdowns
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.navbar__item--dropdown')) {
      closeAllDropdowns();
    }
  });

  // Escape closes dropdowns and returns focus
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const openDropdown = document.querySelector('.navbar__item--dropdown.is-open') as HTMLElement;
      if (openDropdown) {
        closeAllDropdowns();
        const trigger = openDropdown.querySelector('.navbar__link--trigger') as HTMLButtonElement;
        trigger?.focus();
      }
    }
  });

  // Scroll shadow
  const observer = new IntersectionObserver(
    ([e]) => navbar.classList.toggle('is-scrolled', !e.isIntersecting),
    { threshold: 0, rootMargin: '-72px 0px 0px 0px' }
  );
  const sentinel = document.createElement('div');
  sentinel.setAttribute('aria-hidden', 'true');
  sentinel.style.cssText = 'position:absolute;top:0;height:1px;width:1px;pointer-events:none;';
  document.body.prepend(sentinel);
  observer.observe(sentinel);
</script>
