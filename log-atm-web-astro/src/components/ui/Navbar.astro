---
import { SITE } from '../../lib/constants';
import { useTranslations, getLangFromUrl, stripLocaleFromPath, buildLocaleUrl, isRTL } from '../../i18n/utils';
import LanguageSelector from './LanguageSelector.astro';

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
const cleanPath = stripLocaleFromPath(currentPath);
const t = useTranslations(currentLang);

// Construye links localizados para los 4 ítems principales de navegación.
const NAV_ITEMS = [
  { key: 'servicios', path: '/servicios' },
  { key: 'industrias', path: '/industrias' },
  { key: 'nosotros', path: '/nosotros' },
  { key: 'contacto', path: '/contacto' },
] as const;

const navLinks = NAV_ITEMS.map((item) => ({
  href: buildLocaleUrl(currentLang, item.path),
  label: t(`nav.${item.key}`),
  matchPath: item.path,
}));

const homeHref = buildLocaleUrl(currentLang, '/');
const quoteHref = buildLocaleUrl(currentLang, '/cotizar');
const rtl = isRTL(currentLang);
---

<nav class="nav" id="navbar" aria-label={t('a11y.mainNav')}>
  <div class="container nav__inner">
    <a href={homeHref} class="nav__brand" aria-label={t('a11y.brandHome')}>
      <img class="nav__brand-logo" src="/logo.png" alt="" width="38" height="38" loading="eager" fetchpriority="high" />
      <span>
        <span class="nav__brand-name">{t('meta.siteName')}</span>
        <span class="nav__brand-sub">{t('meta.tagline')}</span>
      </span>
    </a>

    <ul class="nav__links" role="list">
      {navLinks.map((l) => (
        <li>
          <a
            class:list={['nav__link', { 'is-active': cleanPath.startsWith(l.matchPath) }]}
            href={l.href}
            aria-current={cleanPath.startsWith(l.matchPath) ? 'page' : undefined}
          >{l.label}</a>
        </li>
      ))}
    </ul>

    <div class="nav__cta-group">
      <LanguageSelector currentLang={currentLang} currentPath={cleanPath} variant="desktop" />
      <a href={quoteHref} class="btn btn--brand btn--sm">{t('nav.quoteCta')}</a>
    </div>

    <!-- Hamburger (visible <880px) -->
    <button class="nav__burger" id="nav-burger" type="button" aria-label={t('a11y.openMenu')} aria-expanded="false" aria-controls="nav-drawer" data-label-open={t('a11y.openMenu')} data-label-close={t('a11y.closeMenu')}>
      <span class="nav__burger-bar"></span>
      <span class="nav__burger-bar"></span>
      <span class="nav__burger-bar"></span>
    </button>
  </div>
</nav>

<!-- Drawer (mobile) -->
<div class:list={['nav-drawer', { 'is-rtl': rtl }]} id="nav-drawer" aria-hidden="true">
  <div class="nav-drawer__backdrop" id="nav-drawer-backdrop"></div>
  <div class="nav-drawer__panel" role="dialog" aria-modal="true" aria-label={t('a11y.menuDialog')}>
    <div class="nav-drawer__header">
      <a href={homeHref} class="nav__brand">
        <img class="nav__brand-logo" src="/logo.png" alt="" width="38" height="38" />
        <span>
          <span class="nav__brand-name">{t('meta.siteName')}</span>
          <span class="nav__brand-sub">{t('meta.tagline')}</span>
        </span>
      </a>
      <button class="nav-drawer__close" id="nav-drawer-close" type="button" aria-label={t('a11y.closeMenu')}>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <ul class="nav-drawer__links" role="list">
      {navLinks.map((l) => (
        <li><a class="nav-drawer__link" href={l.href}>{l.label}</a></li>
      ))}
    </ul>
    <div class="nav-drawer__ctas">
      <a class="btn btn--cta" href={quoteHref}>{t('nav.quoteCta')}</a>
      <a class="btn btn--wa" href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">{t('common.whatsapp')}</a>
    </div>
    <LanguageSelector currentLang={currentLang} currentPath={cleanPath} variant="mobile" />
  </div>
</div>

<style>
  /* ─── Nav (handoff paridad 1:1) ─────────────────────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(248, 247, 246, 0.78);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent);
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }
  .nav.navbar--scrolled {
    box-shadow: 0 4px 24px color-mix(in srgb, var(--color-primary-900) 12%, transparent);
    background: rgba(248, 247, 246, 0.95);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav { transition: none; }
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 72px;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .nav__brand-logo {
    width: 38px;
    height: 38px;
    object-fit: contain;
    display: block;
  }
  .nav__brand > span {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .nav__brand-name { line-height: 1; }
  .nav__brand-sub {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 1px;
  }
  .nav__links {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius-pill);
    transition: background 150ms, color 150ms;
    display: inline-flex;
  }
  .nav__link:hover,
  .nav__link.is-active {
    background: var(--color-surface-alt);
    color: var(--color-brand);
  }
  .nav__cta-group {
    display: flex;
    gap: 0.625rem;
    align-items: center;
  }

  /* ES language pill — placeholder visual (sin i18n por ahora) */
  .nav__lang {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(8px);
    user-select: none;
  }

  /* Hamburger (oculto en desktop) */
  .nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    width: 44px;
    height: 44px;
  }
  .nav__burger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-neutral-800);
    border-radius: var(--radius-sm);
    transition: transform 250ms ease, opacity 250ms ease;
    transform-origin: center;
  }
  .nav__burger[aria-expanded="true"] .nav__burger-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__burger[aria-expanded="true"] .nav__burger-bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav__burger[aria-expanded="true"] .nav__burger-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile breakpoint del handoff: 880px */
  @media (max-width: 880px) {
    .nav__links,
    .nav__cta-group { display: none; }
    .nav__burger { display: flex; }
  }

  /* ─── Drawer mobile (no está en el handoff; añadido para UX) ─ */
  .nav-drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    visibility: hidden;
    pointer-events: none;
  }
  .nav-drawer[aria-hidden="false"] {
    visibility: visible;
    pointer-events: auto;
  }
  .nav-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-primary-900) 55%, transparent);
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .nav-drawer[aria-hidden="false"] .nav-drawer__backdrop { opacity: 1; }
  .nav-drawer__panel {
    position: absolute;
    inset-block-start: 0;
    inset-inline-end: 0;
    width: min(320px, 88vw);
    height: 100dvh;
    background: var(--color-surface);
    box-shadow: -8px 0 48px rgb(15 30 55 / 0.18);
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    gap: 1rem;
    /* `--drawer-offset` permite invertir el origen del slide en RTL */
    --drawer-offset: 100%;
    transform: translateX(var(--drawer-offset));
    transition: transform 250ms cubic-bezier(0.32, 0.72, 0, 1);
    overflow-y: auto;
  }
  /* En RTL el drawer entra desde el inicio lógico (izquierda visual). */
  [dir="rtl"] .nav-drawer__panel,
  .nav-drawer.is-rtl .nav-drawer__panel {
    inset-inline-end: auto;
    inset-inline-start: 0;
    --drawer-offset: -100%;
    box-shadow: 8px 0 48px rgb(15 30 55 / 0.18);
  }
  .nav-drawer[aria-hidden="false"] .nav-drawer__panel { transform: translateX(0); }
  .nav-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .nav-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.625rem;
    border-radius: var(--radius-sm);
    color: var(--color-neutral-600);
    transition: background 150ms, color 150ms;
  }
  .nav-drawer__close:hover { background: var(--color-neutral-100); color: var(--color-neutral-900); }
  .nav-drawer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
  }
  .nav-drawer__link {
    display: block;
    padding: 0.875rem 1rem;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-neutral-700);
    border-radius: var(--radius-sm);
    transition: background 150ms, color 150ms;
  }
  .nav-drawer__link:hover { background: var(--color-primary-50); color: var(--color-brand); }
  .nav-drawer__ctas {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-drawer__panel,
    .nav-drawer__backdrop { transition: none !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Scroll state de la navbar: añade clase .navbar--scrolled al pasar 80px
  const navEl = document.getElementById('navbar');
  if (navEl) {
    ScrollTrigger.create({
      start: 'top -80',
      onToggle: (self) => navEl.classList.toggle('navbar--scrolled', self.isActive),
    });
  }

  // Limpiar ScrollTriggers al navegar con View Transitions
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill());
  });

  const burger     = document.getElementById('nav-burger') as HTMLButtonElement | null;
  const drawer     = document.getElementById('nav-drawer');
  const panel      = drawer?.querySelector<HTMLElement>('.nav-drawer__panel') ?? null;
  const backdrop   = document.getElementById('nav-drawer-backdrop');
  const closeBtn   = document.getElementById('nav-drawer-close') as HTMLButtonElement | null;
  // Marca el resto del documento como inert mientras el drawer está abierto.
  const mainContent = document.getElementById('main-content');
  const nav         = document.getElementById('navbar');
  const inertTargets: HTMLElement[] = [mainContent, nav].filter((el): el is HTMLElement => !!el);

  const FOCUSABLE = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"]), input, select, textarea';

  function setInert(on: boolean) {
    inertTargets.forEach((el) => {
      if (on) el.setAttribute('inert', '');
      else el.removeAttribute('inert');
    });
  }

  function openDrawer() {
    if (!drawer || !burger || !panel) return;
    drawer.setAttribute('aria-hidden', 'false');
    burger.setAttribute('aria-expanded', 'true');
    burger.setAttribute('aria-label', burger.dataset.labelClose ?? 'Cerrar menú');
    document.body.style.overflow = 'hidden';
    setInert(true);
    // Foco al primer elemento focusable del panel (botón cerrar).
    requestAnimationFrame(() => {
      const first = panel.querySelector<HTMLElement>(FOCUSABLE);
      first?.focus();
    });
  }
  function closeDrawer() {
    if (!drawer || !burger) return;
    drawer.setAttribute('aria-hidden', 'true');
    burger.setAttribute('aria-expanded', 'false');
    burger.setAttribute('aria-label', burger.dataset.labelOpen ?? 'Abrir menú');
    document.body.style.overflow = '';
    setInert(false);
    burger.focus();
  }

  // Focus trap: Tab cíclico dentro del panel.
  function trapFocus(e: KeyboardEvent) {
    if (e.key !== 'Tab' || !panel || drawer?.getAttribute('aria-hidden') !== 'false') return;
    const focusables = Array.from(panel.querySelectorAll<HTMLElement>(FOCUSABLE))
      .filter((el) => !el.hasAttribute('disabled') && el.offsetParent !== null);
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last  = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  burger?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => {
    if (drawer?.getAttribute('aria-hidden') !== 'false') return;
    if (e.key === 'Escape') closeDrawer();
    else trapFocus(e);
  });
</script>
