---
import { FOOTER_SERVICES, FOOTER_COMPANY, CURRENT_YEAR, SITE } from '../../lib/constants';
---

<footer class="footer" role="contentinfo">
  <div class="container footer__grid">

    <!-- Brand column -->
    <div class="footer__brand">
      <a href="/" aria-label="LOG ATM — Inicio">
        <img src="/logo-white.svg" alt="LOG ATM" width="100" height="50" loading="lazy" />
      </a>
      <p class="footer__tagline">Logística a tu medida</p>
      <p class="footer__desc">
        Soluciones de transporte aéreo y marítimo personalizadas para empresas chilenas con visión global.
      </p>
      <nav class="footer__social" aria-label="Redes sociales">
        <a href="https://facebook.com/logatm"  aria-label="Facebook"  target="_blank" rel="noopener noreferrer" class="footer__social-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a href="https://twitter.com/logatm"   aria-label="Twitter/X" target="_blank" rel="noopener noreferrer" class="footer__social-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4 4l16 16M4 20L20 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
          </svg>
        </a>
        <a href="https://instagram.com/logatm" aria-label="Instagram" target="_blank" rel="noopener noreferrer" class="footer__social-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
        </a>
      </nav>
    </div>

    <!-- Servicios -->
    <div class="footer__col">
      <h3 class="footer__heading">Servicios</h3>
      <ul class="footer__links" role="list">
        {FOOTER_SERVICES.map(({ href, label }) => (
          <li><a href={href} class="footer__link">{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Empresa -->
    <div class="footer__col">
      <h3 class="footer__heading">Empresa</h3>
      <ul class="footer__links" role="list">
        {FOOTER_COMPANY.map(({ href, label }) => (
          <li><a href={href} class="footer__link">{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contacto -->
    <div class="footer__col">
      <h3 class="footer__heading">Contacto</h3>
      <address class="footer__address">
        <p>
          <a href={`tel:${SITE.phone}`} class="footer__link">{SITE.phone}</a>
        </p>
        <p>
          <a href={`mailto:${SITE.email}`} class="footer__link">{SITE.email}</a>
        </p>
        <p class="footer__address-text">
          {SITE.address.split(', ').slice(0, 2).join(', ')}<br />
          {SITE.address.split(', ').slice(2).join(', ')}
        </p>
      </address>
      <a
        href={SITE.whatsappUrl}
        class="footer__whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.564 4.139 1.543 5.876L0 24l6.324-1.51A11.928 11.928 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-4.997-1.373l-.357-.213-3.753.897.947-3.653-.232-.374A9.773 9.773 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
        </svg>
        Hablar por WhatsApp
      </a>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copyright">
        &copy; {CURRENT_YEAR} {SITE.name}. Todos los derechos reservados.
      </p>
      <div class="footer__legal">
        <a href="/privacidad" class="footer__link-sm">Política de privacidad</a>
        <a href="/terminos"   class="footer__link-sm">Términos de uso</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary-950);
    color: var(--color-primary-200);
    padding-top: 4rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  .footer__brand {}

  .footer__brand img {
    margin-bottom: 0.75rem;
  }

  .footer__tagline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-accent-400);
    margin: 0 0 0.75rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-size: 0.8rem;
  }

  .footer__desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-primary-300);
    margin: 0 0 1.5rem;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--color-primary-800);
    color: var(--color-primary-200);
    transition: background-color 150ms ease, color 150ms ease;
  }

  .footer__social-link:hover {
    background-color: var(--color-brand);
    color: #ffffff;
  }

  .footer__heading {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 1.25rem;
  }

  .footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: var(--color-primary-300);
    transition: color 150ms ease;
  }

  .footer__link:hover {
    color: #ffffff;
  }

  .footer__address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .footer__address p {
    margin: 0;
  }

  .footer__address-text {
    font-size: 0.875rem;
    color: var(--color-primary-300);
    line-height: 1.5;
  }

  .footer__whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background-color: var(--color-whatsapp);
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-pill);
    transition: background-color 150ms ease, transform 100ms ease;
  }

  .footer__whatsapp:hover {
    background-color: var(--color-whatsapp-hover);
    transform: translateY(-1px);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-primary-800);
    padding: 1.25rem 0;
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer__copyright {
    font-size: 0.8125rem;
    color: var(--color-primary-400);
    margin: 0;
  }

  .footer__legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer__link-sm {
    font-size: 0.8125rem;
    color: var(--color-primary-400);
    transition: color 150ms ease;
  }

  .footer__link-sm:hover {
    color: var(--color-primary-200);
  }

  @media (max-width: 1023px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 639px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer__bottom-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
