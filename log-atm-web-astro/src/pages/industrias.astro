---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import CTASection from '../components/sections/CTASection.astro';
import { Icon } from 'astro-icon/components';
import { SITE, INDUSTRIES, IND_TAGS_MAP, SERVICES_PER_IND } from '../lib/constants';
import '../styles/pages/shared.css';

const title = 'Industrias';
const description = '12 sectores con operaciones especializadas, regulaciones particulares y rutas optimizadas. Minería, retail, agro, farma, e-commerce y más.';
const canonical = `${SITE.url}/industrias`;

const spotlight = INDUSTRIES[0]; // Minería
const spotlightTags = IND_TAGS_MAP[spotlight.name] || [];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Navbar />

  <main id="main-content">
    <section class="page-hero">
      <div class="container">
        <div class="page-hero__breadcrumb">
          <a href="/">Inicio</a> <span>/</span> <span>Industrias</span>
        </div>
        <div class="page-hero__inner">
          <div>
            <span class="page-hero__eyebrow">Industrias · 12 sectores</span>
            <h1 class="page-hero__title">Conocemos <em>tu sector</em>.</h1>
            <p class="page-hero__lead">
              Operaciones especializadas, regulaciones particulares y rutas optimizadas.
              Diseñamos la logística según las reglas de tu industria.
            </p>
          </div>
          <div class="page-hero__meta">
            <div class="page-hero__meta-item"><span class="v">12</span><span class="k">Sectores</span></div>
            <div class="page-hero__meta-item"><span class="v">300<em>+</em></span><span class="k">Clientes activos</span></div>
            <div class="page-hero__meta-item"><span class="v">20<em>+</em></span><span class="k">Años de expertise</span></div>
            <div class="page-hero__meta-item"><span class="v">98%</span><span class="k">Retención</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Spotlight: Minería (sector destacado) -->
    <section class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Sector destacado</span>
          <h2 class="section-head__title">Cuando la operación define el negocio</h2>
        </div>
        <div class="ind-spotlight">
          <div class="ind-spotlight__media">
            <img src={spotlight.img} alt={spotlight.name} />
            <div class="ind-spotlight__overlay">
              <span class="ind-spotlight__label">Caso · {spotlight.name}</span>
              <h3 class="ind-spotlight__name">{spotlight.name}</h3>
              <p class="ind-spotlight__sub">{spotlight.sub}</p>
            </div>
          </div>
          <div class="ind-spotlight__panel">
            <span class="ind-spotlight__panel-eyebrow">Cliente desde 2017</span>
            <p class="ind-spotlight__quote">
              Movimos 1.200 contenedores de maquinaria especializada en 8 meses para la
              expansión de una faena, con cero días de detención fuera de programa.
            </p>
            <div class="ind-spotlight__author">
              <strong>Operación enterprise</strong>
              Coordinación FCL · Aduana OEA · Última milla al norte
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Directory editorial (rotación automática + lista) -->
    <section class="section ind-directory-section">
      <div class="container">
        <div class="section-head">
          <div class="section-head__top">
            <div>
              <span class="eyebrow">Todas las industrias</span>
              <h2 class="section-head__title">12 sectores con operación dedicada</h2>
            </div>
            <p class="section-head__desc">
              Pasa el cursor por cada sector para conocer las operaciones más frecuentes.
            </p>
          </div>
        </div>

        <div class="ind-directory" id="ind-directory">
          <div class="ind-directory__viewer">
            {INDUSTRIES.map((it, i) => (
              <div class:list={['ind-directory__slide', { 'is-active': i === 0 }]} data-slide={i}>
                <img src={it.img} alt={it.name} loading="lazy" />
              </div>
            ))}
            <div class="ind-directory__overlay">
              <div class="ind-directory__counter">
                <span id="dir-counter-active">01</span>
                <span class="sep">/</span>
                <span class="total">{String(INDUSTRIES.length).padStart(2, '0')}</span>
              </div>
              <div class="ind-directory__caption">
                <span class="ind-directory__eyebrow" id="dir-eyebrow">Sector · 01</span>
                <h3 class="ind-directory__name" id="dir-name">{spotlight.name}</h3>
                <p class="ind-directory__sub" id="dir-sub">{spotlight.sub}</p>
                <div class="ind-directory__tags" id="dir-tags">
                  {spotlightTags.map((t) => <span class="ind-directory__tag">{t}</span>)}
                </div>
              </div>
            </div>
          </div>

          <ol class="ind-directory__list">
            {INDUSTRIES.map((it, i) => (
              <li>
                <button
                  type="button"
                  class:list={['ind-directory__item', { 'is-active': i === 0 }]}
                  data-item={i}
                >
                  <span class="ind-directory__item-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="ind-directory__item-name">{it.name}</span>
                  <span class="ind-directory__item-arrow" aria-hidden="true">→</span>
                </button>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- Services per industry -->
    <section class="section">
      <div class="container">
        <div class="section-head">
          <div class="section-head__top">
            <div>
              <span class="eyebrow">Por servicio</span>
              <h2 class="section-head__title">Qué movemos en cada sector</h2>
            </div>
            <p class="section-head__desc">
              Combinaciones más frecuentes de servicios por industria.
            </p>
          </div>
        </div>
        <div class="ind-services">
          <div class="ind-services__row ind-services__head">
            <div>Industria</div>
            <div>Servicios habituales</div>
            <div>Cotizar</div>
          </div>
          {INDUSTRIES.map((ind) => (
            <div class="ind-services__row">
              <div class="ind-services__name">{ind.name}</div>
              <div class="ind-services__tags">
                {(SERVICES_PER_IND[ind.name] || []).map((t) => (
                  <span class="ind-services__tag">{t}</span>
                ))}
              </div>
              <a class="ind-services__cta" href="/contacto">
                Hablar
                <Icon name="lucide:arrow-right" width={12} height={12} aria-hidden="true" />
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection />
  </main>

  <Footer />
</BaseLayout>

<script define:vars={{ INDUSTRIES, IND_TAGS_MAP }}>
  const root      = document.getElementById('ind-directory');
  if (root) {
    const slides    = root.querySelectorAll('.ind-directory__slide');
    const items     = root.querySelectorAll('.ind-directory__item');
    const counter   = document.getElementById('dir-counter-active');
    const eyebrowEl = document.getElementById('dir-eyebrow');
    const nameEl    = document.getElementById('dir-name');
    const subEl     = document.getElementById('dir-sub');
    const tagsEl    = document.getElementById('dir-tags');
    const total     = INDUSTRIES.length;

    let active = 0;
    let paused = false;
    let timer  = null;

    function render(i) {
      slides.forEach((s, idx) => s.classList.toggle('is-active', idx === i));
      items.forEach((it, idx)  => it.classList.toggle('is-active', idx === i));
      const ind = INDUSTRIES[i];
      const tags = IND_TAGS_MAP[ind.name] || [];
      const pad = String(i + 1).padStart(2, '0');
      if (counter)   counter.textContent = pad;
      if (eyebrowEl) eyebrowEl.textContent = `Sector · ${pad}`;
      if (nameEl)    nameEl.textContent = ind.name;
      if (subEl)     subEl.textContent  = ind.sub;
      if (tagsEl)    tagsEl.innerHTML = tags.map((t) => `<span class="ind-directory__tag">${t}</span>`).join('');
    }

    function next() {
      active = (active + 1) % total;
      render(active);
    }

    function start() {
      if (timer) return;
      timer = window.setInterval(() => { if (!paused) next(); }, 3500);
    }

    items.forEach((it, idx) => {
      it.addEventListener('mouseenter', () => { active = idx; render(active); });
      it.addEventListener('focus',      () => { active = idx; render(active); });
      it.addEventListener('click',      () => { active = idx; render(active); });
    });
    root.addEventListener('mouseenter', () => { paused = true;  });
    root.addEventListener('mouseleave', () => { paused = false; });

    // Respect prefers-reduced-motion
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (!mq.matches) start();
  }
</script>
