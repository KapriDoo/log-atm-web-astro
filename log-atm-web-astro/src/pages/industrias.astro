---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import CTASection from '../components/sections/CTASection.astro';
import { Icon } from 'astro-icon/components';
import { INDUSTRIES } from '../lib/constants';
import { useTranslations, getLangFromUrl, tList, type Locale } from '../i18n/utils';
import '../styles/pages/shared.css';

const { lang: langProp } = Astro.props as { lang?: Locale };
const currentLang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const title = t('meta.industrias.title');
const description = t('meta.industrias.description');

type IndName = { name: string; sub: string };
const indNames = tList<IndName>(currentLang, 'industrias.names');
const indTags = tList<string[]>(currentLang, 'industrias.tags');
const indServices = tList<string[]>(currentLang, 'industrias.servicesPer');

// Combinar metadata visual (img/color/icon) con copy traducido
const industries = INDUSTRIES.map((ind, i) => ({
  ...ind,
  name: indNames[i]?.name ?? ind.name,
  sub: indNames[i]?.sub ?? ind.sub,
  tags: indTags[i] ?? [],
  services: indServices[i] ?? [],
}));

const spotlight = industries[0];
const sectorPrefix = t('industrias.directory.sectorPrefix');
---

<BaseLayout title={title} description={description} lang={currentLang}>
  <Navbar />

  <main id="main-content">
    <section class="page-hero">
      <div class="container">
        <div class="page-hero__breadcrumb">
          <a href="/">{t('common.breadcrumbHome')}</a> <span>/</span> <span>{t('industrias.breadcrumb')}</span>
        </div>
        <div class="page-hero__inner">
          <div>
            <span class="page-hero__eyebrow" data-hero-animate>{t('industrias.heroEyebrow')}</span>
            <h1 class="page-hero__title" set:html={t('industrias.heroTitleHtml')} data-hero-animate></h1>
            <p class="page-hero__lead" data-hero-animate>{t('industrias.heroLead')}</p>
          </div>
          <div class="page-hero__meta">
            <div class="page-hero__meta-item" data-hero-animate><span class="v">12</span><span class="k">{t('industrias.metaSectors')}</span></div>
            <div class="page-hero__meta-item" data-hero-animate><span class="v">300<em>+</em></span><span class="k">{t('industrias.metaClients')}</span></div>
            <div class="page-hero__meta-item" data-hero-animate><span class="v">20<em>+</em></span><span class="k">{t('industrias.metaExpertise')}</span></div>
            <div class="page-hero__meta-item" data-hero-animate><span class="v">98%</span><span class="k">{t('industrias.metaRetention')}</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Spotlight: sector destacado -->
    <section class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">{t('industrias.spotlight.eyebrow')}</span>
          <h2 class="section-head__title">{t('industrias.spotlight.title')}</h2>
        </div>
        <div class="ind-spotlight">
          <div class="ind-spotlight__media">
            <img src={spotlight.img} alt={spotlight.name} />
            <div class="ind-spotlight__overlay">
              <span class="ind-spotlight__label">{t('industrias.spotlight.caseLabel')} · {spotlight.name}</span>
              <h3 class="ind-spotlight__name">{spotlight.name}</h3>
              <p class="ind-spotlight__sub">{spotlight.sub}</p>
            </div>
          </div>
          <div class="ind-spotlight__panel">
            <span class="ind-spotlight__panel-eyebrow">{t('industrias.spotlight.panelEyebrow')}</span>
            <p class="ind-spotlight__quote">{t('industrias.spotlight.quote')}</p>
            <div class="ind-spotlight__author">
              <strong>{t('industrias.spotlight.authorTitle')}</strong>
              {t('industrias.spotlight.authorDetail')}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Directory editorial (rotación automática + lista) -->
    <section class="section ind-directory-section">
      <div class="container">
        <div class="section-head">
          <div class="section-head__top">
            <div>
              <span class="eyebrow">{t('industrias.directory.eyebrow')}</span>
              <h2 class="section-head__title">{t('industrias.directory.title')}</h2>
            </div>
            <p class="section-head__desc">{t('industrias.directory.desc')}</p>
          </div>
        </div>

        <div class="ind-directory" id="ind-directory">
          <div class="ind-directory__viewer">
            {industries.map((it, i) => (
              <div class:list={['ind-directory__slide', { 'is-active': i === 0 }]} data-slide={i}>
                <img src={it.img} alt={it.name} loading="lazy" />
              </div>
            ))}
            <div class="ind-directory__overlay">
              <div class="ind-directory__counter">
                <span id="dir-counter-active">01</span>
                <span class="sep">/</span>
                <span class="total">{String(industries.length).padStart(2, '0')}</span>
              </div>
              <div class="ind-directory__caption">
                <span class="ind-directory__eyebrow" id="dir-eyebrow">{sectorPrefix} · 01</span>
                <h3 class="ind-directory__name" id="dir-name">{spotlight.name}</h3>
                <p class="ind-directory__sub" id="dir-sub">{spotlight.sub}</p>
                <div class="ind-directory__tags" id="dir-tags">
                  {spotlight.tags.map((tag) => <span class="ind-directory__tag">{tag}</span>)}
                </div>
              </div>
            </div>
          </div>

          <ol class="ind-directory__list">
            {industries.map((it, i) => (
              <li>
                <button
                  type="button"
                  class:list={['ind-directory__item', { 'is-active': i === 0 }]}
                  data-item={i}
                >
                  <span class="ind-directory__item-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="ind-directory__item-name">{it.name}</span>
                  <span class="ind-directory__item-arrow" aria-hidden="true">→</span>
                </button>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- Services per industry -->
    <section class="section">
      <div class="container">
        <div class="section-head">
          <div class="section-head__top">
            <div>
              <span class="eyebrow">{t('industrias.services.eyebrow')}</span>
              <h2 class="section-head__title">{t('industrias.services.title')}</h2>
            </div>
            <p class="section-head__desc">{t('industrias.services.desc')}</p>
          </div>
        </div>
        <div class="ind-services">
          <div class="ind-services__row ind-services__head">
            <div>{t('industrias.services.colIndustry')}</div>
            <div>{t('industrias.services.colServices')}</div>
            <div>{t('industrias.services.colCta')}</div>
          </div>
          {industries.map((ind) => (
            <div class="ind-services__row">
              <div class="ind-services__name">{ind.name}</div>
              <div class="ind-services__tags">
                {ind.services.map((s) => (
                  <span class="ind-services__tag">{s}</span>
                ))}
              </div>
              <a class="ind-services__cta" href="/contacto">
                {t('industrias.services.rowCta')}
                <Icon name="lucide:arrow-right" width={12} height={12} aria-hidden="true" />
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection />
  </main>

  <Footer />
</BaseLayout>

<script define:vars={{ industries, sectorPrefix }}>
  // Datos del DOM para las captions (counter, eyebrow, name, sub, tags)
  const counter   = document.getElementById('dir-counter-active');
  const eyebrowEl = document.getElementById('dir-eyebrow');
  const nameEl    = document.getElementById('dir-name');
  const subEl     = document.getElementById('dir-sub');
  const tagsEl    = document.getElementById('dir-tags');

  // Callback que actualiza el texto de caption y counter al cambiar de slide
  function onRender(i) {
    const ind = industries[i];
    const tags = ind.tags || [];
    const pad = String(i + 1).padStart(2, '0');
    if (counter)   counter.textContent = pad;
    if (eyebrowEl) eyebrowEl.textContent = `${sectorPrefix} · ${pad}`;
    if (nameEl)    nameEl.textContent = ind.name;
    if (subEl)     subEl.textContent  = ind.sub;
    if (tagsEl)    tagsEl.innerHTML = tags.map((t) => `<span class="ind-directory__tag">${t}</span>`).join('');
  }

  // Exponer callback para que el script GSAP lo consuma
  window.__indDirectoryOnRender = onRender;
</script>

<script>
  import { initIndDirectory } from '../scripts/gsap-ind-directory';

  document.addEventListener('astro:page-load', () => {
    const onRender = (window as Window & { __indDirectoryOnRender?: (i: number) => void }).__indDirectoryOnRender;
    initIndDirectory('#ind-directory', {
      intervalMs: 3500,
      onRender,
    });
  });
</script>
