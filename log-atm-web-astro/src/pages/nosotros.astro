---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import CTASection from '../components/sections/CTASection.astro';
import { Icon } from 'astro-icon/components';
import { SITE, TIMELINE, VALUES, HOW_WE_WORK, CERTS } from '../lib/constants';
import { useTranslations, getLangFromUrl } from '../i18n/utils';
import '../styles/pages/shared.css';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const title = t('meta.nosotros.title');
const description = t('meta.nosotros.description');
const canonical = `${SITE.url}/nosotros`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Navbar />

  <main id="main-content">
    <section class="page-hero">
      <div class="container">
        <div class="page-hero__breadcrumb">
          <a href="/">Inicio</a> <span>/</span> <span>Nosotros</span>
        </div>
        <div class="page-hero__inner">
          <div>
            <span class="page-hero__eyebrow">Nosotros · Desde 2003</span>
            <h1 class="page-hero__title">
              20+ años conectando <em>Chile con el mundo</em>.
            </h1>
            <p class="page-hero__lead">
              Somos un operador logístico chileno. No vendemos un servicio: operamos
              con cada cliente como si fuera nuestra propia operación.
            </p>
          </div>
          <div class="page-hero__meta">
            <div class="page-hero__meta-item"><span class="v">20<em>+</em></span><span class="k">Años de operación</span></div>
            <div class="page-hero__meta-item"><span class="v">CL</span><span class="k">Capital chileno</span></div>
            <div class="page-hero__meta-item"><span class="v">OEA</span><span class="k">Operador autorizado</span></div>
            <div class="page-hero__meta-item"><span class="v">B2B</span><span class="k">Foco corporativo</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="manifesto">
      <div class="container">
        <div class="manifesto__grid">
          <h2 class="manifesto__title">
            La logística es una <em>relación</em>, no un commodity.
          </h2>
          <div class="manifesto__body">
            <p>
              Llevamos más de dos décadas operando en el mundo logístico chileno y aprendimos
              algo simple: <em>las cargas no se mueven solas</em>. Detrás de cada contenedor,
              cada AWB, cada DUS, hay personas decidiendo bajo presión.
            </p>
            <p>
              Por eso construimos LOG ATM al revés que la industria. En lugar de un call center
              que rota agentes, asignamos un ejecutivo dedicado por cuenta. En lugar de tarifas
              ocultas, mostramos cada componente del costo. En lugar de prometer todo, decimos
              primero lo que va a fallar.
            </p>
            <p>
              Hoy operamos en <em>70+ países</em>, con clientes en 12 industrias y una retención
              del 98%. Pero seguimos midiéndonos con la misma pregunta del primer día: ¿el cliente
              sentiría que esta operación es suya?
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="timeline">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Trayectoria</span>
          <h2 class="section-head__title">Hitos de 20+ años</h2>
        </div>
        <div class="timeline__track">
          <div class="timeline__line"></div>
          <div class="timeline__items">
            {TIMELINE.map((t) => (
              <div class="timeline__item">
                <div class="timeline__dot"></div>
                <div class="timeline__year">{t.year}</div>
                <h3 class="timeline__milestone">{t.milestone}</h3>
                <p class="timeline__desc">{t.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section section--surface">
      <div class="container">
        <div class="section-head">
          <div class="section-head__top">
            <div>
              <span class="eyebrow">Cómo trabajamos</span>
              <h2 class="section-head__title">4 valores que defienden la operación</h2>
            </div>
            <p class="section-head__desc">
              Los principios que aplicamos en cada decisión, desde cotizar hasta resolver
              una contingencia a las 3 AM.
            </p>
          </div>
        </div>
        <div class="values-grid">
          {VALUES.map((v) => (
            <div class="value-card">
              <div class="value-card__icon">
                <Icon name={v.icon} width={22} height={22} />
              </div>
              <h3 class="value-card__title">{v.title}</h3>
              <p class="value-card__desc">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <div class="section-head">
          <div class="section-head__top">
            <div>
              <span class="eyebrow">Cómo trabajamos</span>
              <h2 class="section-head__title">Un modelo simple, transparente y a tu medida</h2>
            </div>
            <p class="section-head__desc">
              No vendemos paquetes cerrados. Diseñamos cada operación desde cero
              siguiendo cuatro pasos claros, con un ejecutivo que te acompaña de
              principio a fin.
            </p>
          </div>
        </div>
        <div class="howwork-grid">
          {HOW_WE_WORK.map((s) => (
            <div class="howwork-card">
              <div class="howwork-card__media">
                <img src={s.img} alt="" loading="lazy" />
                <span class="howwork-card__step">{s.step}</span>
                <span class="howwork-card__icon">
                  <Icon name={s.icon} width={18} height={18} />
                </span>
              </div>
              <div class="howwork-card__body">
                <h3 class="howwork-card__title">{s.title}</h3>
                <p class="howwork-card__desc">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--surface">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Certificaciones</span>
          <h2 class="section-head__title">Operamos bajo estándares globales</h2>
        </div>
        <div class="certs">
          {CERTS.map((c) => (
            <div class="cert">
              <div class="cert__seal">{c.name.split(' ')[0].slice(0, 4).toUpperCase()}</div>
              <h3 class="cert__name">{c.name}</h3>
              <p class="cert__desc">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection />
  </main>

  <Footer />
</BaseLayout>
