---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import CTASection from '../components/sections/CTASection.astro';
import Icon from "../components/ui/Icon.astro";
import { Picture } from 'astro:assets';
import { VALUES, HOW_WE_WORK } from '../lib/constants';
import { useTranslations, getLangFromUrl, tList, type Locale } from '../i18n/utils';
import '../styles/pages/shared.css';

const { lang: langProp } = Astro.props as { lang?: Locale };
const currentLang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const title = t('meta.nosotros.title');
const description = t('meta.nosotros.description');

type ValueItem = { title: string; desc: string };
type HowItem = { title: string; desc: string };

const valuesCopy = tList<ValueItem>(currentLang, 'nosotros.values.items');
const howCopy = tList<HowItem>(currentLang, 'nosotros.how.items');

const values = VALUES.map((v, i) => ({ ...v, ...(valuesCopy[i] ?? { title: v.title, desc: v.desc }) }));
const how = HOW_WE_WORK.map((h, i) => ({ ...h, ...(howCopy[i] ?? { title: h.title, desc: h.desc }) }));
---

<BaseLayout title={title} description={description} lang={currentLang}>
  <Navbar />

  <main id="main-content">
    <section class="page-hero">
      <div class="container">
        <div class="page-hero__breadcrumb">
          <a href="/">{t('common.breadcrumbHome')}</a> <span>/</span> <span>{t('nosotros.breadcrumb')}</span>
        </div>
        <div class="page-hero__inner">
          <div>
            <span class="page-hero__eyebrow" data-hero-animate>{t('nosotros.heroEyebrow')}</span>
            <h1 class="page-hero__title" set:html={t('nosotros.heroTitleHtml')} data-hero-animate></h1>
            <p class="page-hero__lead" data-hero-animate>{t('nosotros.heroLead')}</p>
          </div>
          <div class="page-hero__meta">
            <div class="page-hero__meta-item" data-hero-animate><span class="v">20<em>+</em></span><span class="k">{t('nosotros.metaYears')}</span></div>
            <div class="page-hero__meta-item" data-hero-animate><span class="v">CL</span><span class="k">{t('nosotros.metaCapital')}</span></div>
            <div class="page-hero__meta-item" data-hero-animate><span class="v">OEA</span><span class="k">{t('nosotros.metaCert')}</span></div>
            <div class="page-hero__meta-item" data-hero-animate><span class="v">B2B</span><span class="k">{t('nosotros.metaFocus')}</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="manifesto">
      <div class="container">
        <div class="manifesto__grid">
          <h2 class="manifesto__title" set:html={t('nosotros.manifesto.titleHtml')}></h2>
          <div class="manifesto__body">
            <p set:html={t('nosotros.manifesto.p1Html')}></p>
            <p>{t('nosotros.manifesto.p2')}</p>
            <p set:html={t('nosotros.manifesto.p3Html')}></p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section--surface">
      <div class="container">
        <div class="section-head">
          <div class="section-head__top">
            <div>
              <span class="eyebrow">{t('nosotros.values.eyebrow')}</span>
              <h2 class="section-head__title">{t('nosotros.values.title')}</h2>
            </div>
            <p class="section-head__desc">{t('nosotros.values.desc')}</p>
          </div>
        </div>
        <div class="values-grid">
          {values.map((v) => (
            <div class="value-card">
              <div class="value-card__icon">
                <Icon name={v.icon} width={22} height={22} />
              </div>
              <h3 class="value-card__title">{v.title}</h3>
              <p class="value-card__desc">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <div class="section-head">
          <div class="section-head__top">
            <div>
              <span class="eyebrow">{t('nosotros.how.eyebrow')}</span>
              <h2 class="section-head__title">{t('nosotros.how.title')}</h2>
            </div>
            <p class="section-head__desc">{t('nosotros.how.desc')}</p>
          </div>
        </div>
        <div class="howwork-grid">
          {how.map((s) => (
            <div class="howwork-card">
              <div class="howwork-card__media">
                <Picture src={s.img} formats={['avif', 'webp']} alt={s.title} quality={80} />
                <span class="howwork-card__step">{s.step}</span>
                <span class="howwork-card__icon">
                  <Icon name={s.icon} width={18} height={18} />
                </span>
              </div>
              <div class="howwork-card__body">
                <h3 class="howwork-card__title">{s.title}</h3>
                <p class="howwork-card__desc">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection />
  </main>

  <Footer />
</BaseLayout>
