---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/ui/Footer.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from '../../lib/constants';

const title = 'Carga Marítima';
const description = 'Servicios de carga marítima internacional: FCL, LCL y consolidación. Conectamos Chile con los principales puertos del mundo. Cotiza con LOG ATM.';
const canonical = `${SITE.url}/servicios/carga-maritima`;

const schemaService = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Carga Marítima - LOG ATM',
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'LOG ATM',
    url: SITE.url,
  },
  areaServed: 'CL',
  serviceType: 'FreightTransportation',
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceSpecification: {
      '@type': 'PriceSpecification',
      price: '0',
      priceCurrency: 'CLP',
      description: 'Cotización personalizada',
    },
  },
});
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Navbar />

  <main id="main-content">
    <!-- Hero -->
    <section class="service-hero" aria-labelledby="service-title">
      <div class="service-hero__bg" aria-hidden="true">
        <div class="service-hero__blob"></div>
      </div>
      <div class="container service-hero__inner">
        <div class="service-hero__content">
          <span class="eyebrow">Servicios</span>
          <h1 id="service-title" class="service-hero__title">Carga Marítima</h1>
          <p class="service-hero__lead">
            FCL y LCL a los principales puertos del mundo. Consolidamos tu carga
            para reducir costos sin comprometer los plazos.
          </p>
          <div class="service-hero__actions">
            <a href="/cotizar" class="btn-primary">Cotizar ahora</a>
            <a href={SITE.whatsappUrl} class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.564 4.139 1.543 5.876L0 24l6.324-1.51A11.928 11.928 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-4.997-1.373l-.357-.213-3.753.897.947-3.653-.232-.374A9.773 9.773 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
              </svg>
              Consultar por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="service-features" aria-labelledby="features-title">
      <div class="container">
        <h2 id="features-title" class="section-title">¿Por qué elegir nuestra carga marítima?</h2>
        <div class="features-grid">
          {[
            { icon: 'lucide:ship', title: 'FCL y LCL', desc: 'Contenedor completo o carga consolidada según tus necesidades.' },
            { icon: 'lucide:globe', title: '80+ puertos', desc: 'Cobertura en los principales puertos de Asia, Europa y América.' },
            { icon: 'lucide:package', title: 'Consolidación', desc: 'Agrupamos tu carga con otros clientes para reducir costos.' },
            { icon: 'lucide:headphones', title: 'Ejecutivo dedicado', desc: 'Un solo punto de contacto para todo tu envío.' },
          ].map(({ icon, title, desc }) => (
            <div class="feature-card">
              <div class="feature-card__icon" aria-hidden="true">
                <Icon name={icon} width="28" height="28" />
              </div>
              <h3 class="feature-card__title">{title}</h3>
              <p class="feature-card__desc">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="service-cta" aria-labelledby="cta-title">
      <div class="container service-cta__inner">
        <h2 id="cta-title" class="service-cta__title">¿Necesitas enviar carga marítima?</h2>
        <p class="service-cta__desc">Cotiza en 2 minutos y recibe una propuesta en menos de 24 horas.</p>
        <a href="/cotizar" class="btn-cta">Solicitar cotización</a>
      </div>
    </section>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={schemaService} />
</BaseLayout>

<style>
  .service-hero {
    position: relative;
    background: linear-gradient(150deg, var(--color-primary-950) 0%, var(--color-primary-800) 45%, var(--color-primary-600) 100%);
    overflow: hidden;
    padding: clamp(4rem, 10vw, 7rem) 0 clamp(3rem, 6vw, 5rem);
  }
  .service-hero__bg {
    position: absolute; inset: 0; pointer-events: none;
  }
  .service-hero__blob {
    position: absolute;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: var(--color-primary-400);
    filter: blur(100px);
    opacity: 0.2;
    top: -100px; right: -150px;
  }
  .service-hero__inner {
    position: relative;
    text-align: center;
    max-width: 800px;
  }
  .service-hero__content {
    color: var(--color-text-inverse);
  }
  .service-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin: 0 0 1rem;
  }
  .service-hero__lead {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--color-primary-200);
    line-height: 1.6;
    margin: 0 0 2rem;
  }
  .service-hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    background: var(--color-cta);
    color: var(--color-text-inverse);
    font-weight: 600;
    transition: background 150ms;
  }
  .btn-primary:hover { background: var(--color-accent-600); }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    background: rgba(255,255,255,0.1);
    color: var(--color-text-inverse);
    font-weight: 500;
    border: 1px solid rgba(255,255,255,0.2);
    transition: background 150ms;
  }
  .btn-whatsapp:hover { background: rgba(255,255,255,0.2); }

  .service-features {
    padding: clamp(4rem, 8vw, 6rem) 0;
    background: var(--color-bg);
  }
  .service-features .section-title {
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 3rem;
    color: var(--color-neutral-900);
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2rem;
    transition: box-shadow 300ms, transform 300ms;
  }
  .feature-card:hover {
    box-shadow: 0 12px 40px rgba(74,123,181,0.12);
    transform: translateY(-4px);
  }
  .feature-card__icon {
    width: 56px; height: 56px;
    border-radius: 16px;
    background: var(--color-primary-50);
    color: var(--color-brand);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .feature-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--color-neutral-900);
  }
  .feature-card__desc {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .service-cta {
    padding: clamp(4rem, 8vw, 6rem) 0;
    background: linear-gradient(150deg, var(--color-primary-900) 0%, var(--color-primary-800) 100%);
    text-align: center;
  }
  .service-cta__inner { color: var(--color-text-inverse); }
  .service-cta__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    margin: 0 0 1rem;
  }
  .service-cta__desc {
    font-size: 1.125rem;
    color: var(--color-primary-200);
    margin: 0 0 2rem;
  }
  .btn-cta {
    display: inline-flex;
    padding: 1rem 2rem;
    border-radius: 9999px;
    background: var(--color-cta);
    color: var(--color-text-inverse);
    font-weight: 700;
    font-size: 1.125rem;
    transition: background 150ms, transform 150ms;
  }
  .btn-cta:hover { background: var(--color-accent-600); transform: translateY(-2px); }
</style>
