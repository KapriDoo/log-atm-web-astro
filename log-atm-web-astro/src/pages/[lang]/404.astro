---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/ui/Footer.astro';
import { NON_DEFAULT_LOCALES } from '../../i18n/config';
import { useTranslations, buildLocaleUrl, type Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = (Astro.params.lang ?? 'es') as Locale;
const t = useTranslations(lang);
const currentPath = `/${lang}/404`;
---

<BaseLayout
  title={t('pages.404.title')}
  description={t('pages.404.description')}
  noindex={true}
  lang={lang}
  currentPath={currentPath}
>
  <Navbar lang={lang} currentPath={currentPath} />
  <main id="main-content" class="error-page" role="main">
    <div class="error-page__container">
      <span class="error-page__code" aria-hidden="true">{t('pages.404.code')}</span>
      <h1 class="error-page__title">{t('pages.404.h1')}</h1>
      <p class="error-page__lead">{t('pages.404.lead')}</p>
      <a href={buildLocaleUrl(lang, '/')} class="error-page__cta">
        {t('pages.404.backHome')}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
  .error-page { min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 4rem 1.5rem; text-align: center; }
  .error-page__container { max-width: 480px; }
  .error-page__code { display: block; font-family: var(--font-display); font-size: clamp(6rem, 15vw, 10rem); font-weight: 900; line-height: 1; color: var(--color-primary-200); margin-bottom: 1rem; }
  .error-page__title { font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: var(--color-neutral-900); margin-bottom: 0.75rem; }
  .error-page__lead { font-size: 1.125rem; color: var(--color-text-muted); margin-bottom: 2rem; line-height: 1.6; }
  .error-page__cta { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; border-radius: var(--radius-pill); background: var(--color-cta); color: var(--color-text-inverse); font-weight: 600; font-size: 1rem; transition: background 150ms; }
  .error-page__cta:hover { background: var(--color-accent-600); }
</style>
