---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ServicesSection from '../components/sections/ServicesSection.astro';
import WhyVideoSection from '../components/sections/WhyVideoSection.astro';
import IndustriesSection from '../components/sections/IndustriesSection.astro';
import CTASection from '../components/sections/CTASection.astro';
import { useTranslations, getLangFromUrl, type Locale } from '../i18n/utils';
import '../styles/sections.css';

const { lang: langProp } = Astro.props as { lang?: Locale };
const currentLang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---

<BaseLayout
  title={t('meta.home.title')}
  description={t('meta.home.description')}
  lang={currentLang}
>
  <Navbar />

  <main id="main-content">
    <HeroSection />
    <ServicesSection />
    <WhyVideoSection />
    <IndustriesSection />
    <CTASection />
  </main>

  <Footer />
</BaseLayout>
