---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import StatsSection from '../components/sections/StatsSection.astro';
import ServicesSection from '../components/sections/ServicesSection.astro';
import WhySection from '../components/sections/WhySection.astro';
import IndustriesSection from '../components/sections/IndustriesSection.astro';
import CTASection from '../components/sections/CTASection.astro';
import '../styles/sections.css';
import { useTranslations, type Locale } from '../i18n/utils';

const lang: Locale = 'es';
const currentPath = '/';
const t = useTranslations(lang);
---

<BaseLayout
  lang={lang}
  currentPath={currentPath}
  title={t('pages.home.title')}
  description={t('pages.home.description')}
>
  <Navbar lang={lang} currentPath={currentPath} />

  <main id="main-content">
    <HeroSection lang={lang} />
    <StatsSection lang={lang} />
    <ServicesSection lang={lang} />
    <WhySection lang={lang} />
    <IndustriesSection lang={lang} />
    <CTASection lang={lang} />
  </main>

  <Footer lang={lang} />
</BaseLayout>
