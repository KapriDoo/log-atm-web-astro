---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout
  title="Logística Aérea y Marítima"
  description="LOG ATM — Soluciones de carga aérea, carga marítima, aduana y almacenaje personalizadas para empresas chilenas. Cotiza ahora."
>
  <Navbar />

  <main id="main-content">

    <!-- ══════════════════════════════════════════════════════
         HERO
    ══════════════════════════════════════════════════════ -->
    <section class="hero" aria-labelledby="hero-heading">

      <!-- Decorativos de fondo -->
      <div class="hero__bg" aria-hidden="true">
        <div class="hero__blob hero__blob--1"></div>
        <div class="hero__blob hero__blob--2"></div>
        <div class="hero__grid-lines"></div>
      </div>

      <div class="hero__inner container">
        <div class="hero__content">

          <!-- Badge de eyebrow -->
          <div class="hero__badge">
            <span class="hero__badge-dot" aria-hidden="true"></span>
            Logística internacional desde Santiago, Chile
          </div>

          <h1 id="hero-heading" class="hero__title">
            Tu carga,
            <span class="hero__title-gradient">nuestra ruta.</span>
          </h1>

          <p class="hero__lead">
            Conectamos Chile con el mundo. Carga aérea, marítima y gestión
            aduanera <em>diseñada a tu medida</em>, con un ejecutivo dedicado
            que conoce tu negocio.
          </p>

          <div class="hero__ctas">
            <a href="/cotizar" class="hero__btn-cta">
              Cotiza ahora
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="https://wa.me/56942162739?text=Hola%2C%20me%20interesa%20cotizar" class="hero__btn-wa" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.564 4.139 1.543 5.876L0 24l6.324-1.51A11.928 11.928 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-4.997-1.373l-.357-.213-3.753.897.947-3.653-.232-.374A9.773 9.773 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
              WhatsApp
            </a>
          </div>

          <!-- Mini trust -->
          <div class="hero__trust">
            <div class="hero__trust-avatars" aria-hidden="true">
              {['#658fc3','#3b6497','#4A7BB5'].map(c => (
                <span class="hero__trust-avatar" style={`background:${c}`}></span>
              ))}
            </div>
            <p class="hero__trust-text">+200 empresas confían en LOG ATM</p>
          </div>

        </div>

        <!-- Cards flotantes — efecto "fanned" estilo Lifecare -->
        <div class="hero__cards" aria-hidden="true">
          <div class="hero__card hero__card--back">
            <div class="hero__card-icon"><Icon name="lucide:ship" width="28" height="28" /></div>
            <div>
              <p class="hero__card-label">Carga Marítima</p>
              <p class="hero__card-sub">FCL / LCL · 80+ puertos</p>
            </div>
          </div>
          <div class="hero__card hero__card--mid">
            <div class="hero__card-icon"><Icon name="lucide:plane" width="28" height="28" /></div>
            <div>
              <p class="hero__card-label">Carga Aérea</p>
              <p class="hero__card-sub">Express · 48h garantizado</p>
            </div>
          </div>
          <div class="hero__card hero__card--front">
            <div class="hero__card-top">
              <span class="hero__card-status"></span>
              <p class="hero__card-label">Envío en tránsito</p>
            </div>
            <p class="hero__card-tracking">LOG-2025-04872</p>
            <div class="hero__card-progress">
              <div class="hero__card-bar"></div>
            </div>
            <p class="hero__card-eta">Llegada estimada: 3 días</p>
          </div>
        </div>
      </div>

      <!-- Wave hacia la siguiente sección -->
      <div class="hero__wave" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0,60 C240,20 480,80 720,40 C960,0 1200,60 1440,40 L1440,80 L0,80 Z" fill="var(--color-bg)"/>
        </svg>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         STATS — banda de confianza
    ══════════════════════════════════════════════════════ -->
    <section class="stats" aria-label="Cifras LOG ATM">
      <div class="container stats__inner">
        {[
          { value: '15+',    label: 'Años de experiencia', icon: 'lucide:award',    anim: 'award'    },
          { value: '80+',    label: 'Países conectados',   icon: 'lucide:globe',    anim: 'globe'    },
          { value: '5.000+', label: 'Envíos por año',      icon: 'lucide:package',  anim: 'package'  },
          { value: '98%',    label: 'Satisfacción',        icon: 'lucide:sparkles', anim: 'sparkles' },
        ].map(({ value, label, icon, anim }) => (
          <div class="stats__item">
            <div class={`stats__icon-wrap stats__icon-wrap--${anim}`} aria-hidden="true">
              <Icon name={icon} width="26" height="26" />
            </div>
            <strong class="stats__value">{value}</strong>
            <span class="stats__label">{label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SERVICIOS
    ══════════════════════════════════════════════════════ -->
    <section class="services" aria-labelledby="services-heading">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Qué hacemos</span>
          <h2 id="services-heading" class="section-title">
            Soluciones para<br/>cada necesidad
          </h2>
          <p class="section-lead">
            Desde el despacho urgente hasta la consultoría de supply chain completa.
          </p>
        </div>

        <div class="services__grid">
          {[
            { n:'01', icon:'lucide:plane-takeoff', title:'Carga Aérea',           desc:'Envíos urgentes, courier internacional y chárter aéreo con cobertura global y tiempos optimizados.',    href:'/servicios/carga-aerea',    accent:false },
            { n:'02', icon:'lucide:ship',          title:'Carga Marítima',        desc:'FCL y LCL a los principales puertos del mundo. Consolidamos tu carga para reducir costos.',              href:'/servicios/carga-maritima', accent:false },
            { n:'03', icon:'lucide:file-check',    title:'Aduana y Documentación',desc:'Gestión integral de trámites aduaneros, DUS, certificados de origen y clasificación arancelaria.',       href:'/servicios/aduanas',        accent:true  },
            { n:'04', icon:'lucide:warehouse',     title:'Almacenaje',            desc:'Bodegaje seguro, fulfillment y distribución última milla con gestión de inventario en tiempo real.',       href:'/servicios/almacenaje',     accent:false },
            { n:'05', icon:'lucide:compass',       title:'Consultoría Logística', desc:'Diseñamos tu supply chain a medida. Reducimos costos y plazos con soluciones personalizadas.',           href:'/cotizar',                  accent:true  },
          ].map(({ n, icon, title, desc, href, accent }) => (
            <a href={href} class:list={['svc-card', accent && 'svc-card--accent']}>
              <!-- Línea superior animada -->
              <div class="svc-card__line" aria-hidden="true"></div>
              <!-- Header: número + flecha -->
              <div class="svc-card__header">
                <span class="svc-card__num" aria-hidden="true">{n}</span>
                <span class="svc-card__arrow" aria-hidden="true">
                  <Icon name="lucide:arrow-up-right" width="18" height="18" />
                </span>
              </div>
              <!-- Icono en contenedor coloreado -->
              <div class="svc-card__icon-wrap" aria-hidden="true">
                <Icon name={icon} width="28" height="28" class="svc-card__icon" />
              </div>
              <h3 class="svc-card__title">{title}</h3>
              <p class="svc-card__desc">{desc}</p>
              <!-- Overlay reveal estilo Lifecare -->
              <div class="svc-card__overlay" aria-hidden="true">
                <span class="svc-card__overlay-label">Ver más →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         POR QUÉ ELEGIRNOS
    ══════════════════════════════════════════════════════ -->
    <section class="why" aria-labelledby="why-heading">
      <div class="container why__inner">

        <!-- Visual -->
        <div class="why__visual">
          <div class="why__img-wrap">
            <!-- Placeholder hasta tener foto real del equipo -->
            <div class="why__img-ph">
              <svg viewBox="0 0 520 420" xmlns="http://www.w3.org/2000/svg">
                <rect width="520" height="420" fill="#aec7e5"/>
                <text x="260" y="215" text-anchor="middle" font-size="13" fill="#2b4e78" font-family="sans-serif">Foto equipo / operación portuaria</text>
              </svg>
            </div>
            <!-- Badge flotante -->
            <div class="why__badge">
              <span class="why__badge-icon">🇨🇱</span>
              <div>
                <p class="why__badge-title">Empresa chilena</p>
                <p class="why__badge-sub">con red global</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contenido -->
        <div class="why__content">
          <span class="eyebrow">Por qué LOG ATM</span>
          <h2 id="why-heading" class="section-title">
            Personas. Confianza.<br/>Resultados.
          </h2>
          <p class="section-lead why__lead">
            No somos una multinacional anónima. Somos un equipo chileno con
            conexiones globales y el compromiso de tratarte como nuestro único cliente.
          </p>

          <ul class="why__list" role="list">
            {[
              { icon:'lucide:user-round-check', title:'Ejecutivo dedicado',        desc:'Una persona que conoce tu negocio y anticipa tus necesidades.',  anim:'' },
              { icon:'lucide:globe-2',          title:'Red en 80+ países',         desc:'Alianzas verificadas para garantizar tus plazos de entrega.',    anim:'' },
              { icon:'lucide:map-pin',          title:'Rastreo en tiempo real',    desc:'Visualiza el estado de tu carga en cada etapa del proceso.',     anim:'pin-pulse' },
              { icon:'lucide:shield-check',     title:'Expertise en aduana Chile', desc:'Operadores certificados por el Servicio Nacional de Aduanas.',   anim:'' },
            ].map(({ icon, title, desc, anim }) => (
              <li class="why__item">
                <div class:list={['why__item-icon', anim && `why__item-icon--${anim}`]} aria-hidden="true">
                  <Icon name={icon} width="22" height="22" />
                </div>
                <div>
                  <strong class="why__item-title">{title}</strong>
                  <p class="why__item-desc">{desc}</p>
                </div>
              </li>
            ))}
          </ul>

          <a href="/nosotros" class="why__btn">Conoce al equipo</a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         INDUSTRIAS
    ══════════════════════════════════════════════════════ -->
    <section class="industries" aria-labelledby="industries-heading">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Industrias</span>
          <h2 id="industries-heading" class="section-title">Experiencia en tu sector</h2>
        </div>
        <div class="industries__grid">
          {[
            { icon:'lucide:pickaxe',       name:'Minería',       sub:'Cobre, litio, equipamiento pesado',  color:'#658fc3' },
            { icon:'lucide:shopping-bag',  name:'Retail',        sub:'Moda, consumo masivo, temporada',    color:'#ed8c1d' },
            { icon:'lucide:wheat',         name:'Agroindustria', sub:'Fruta fresca, vinos, granos',        color:'#2D9B6F' },
            { icon:'lucide:pill',          name:'Farmacéutica',  sub:'Cadena de frío, reactivos',          color:'#4A7BB5' },
            { icon:'lucide:shopping-cart', name:'E-commerce',    sub:'Cross-border, fulfillment',          color:'#cc7614' },
            { icon:'lucide:hard-hat',      name:'Construcción',  sub:'Maquinaria, materiales',             color:'#3b6497' },
          ].map(({ icon, name, sub, color }) => (
            <div class="ind-card" style={`--ind-color:${color}`}>
              <div class="ind-card__glow" aria-hidden="true"></div>
              <div class="ind-card__icon-wrap" aria-hidden="true">
                <Icon name={icon} width="28" height="28" class="ind-card__icon" />
              </div>
              <h3 class="ind-card__name">{name}</h3>
              <p class="ind-card__sub">{sub}</p>
              <span class="ind-card__arrow" aria-hidden="true">→</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         CTA BANNER
    ══════════════════════════════════════════════════════ -->
    <section class="cta-section" aria-labelledby="cta-heading">
      <div class="cta-section__bg" aria-hidden="true">
        <div class="cta-section__blob cta-section__blob--1"></div>
        <div class="cta-section__blob cta-section__blob--2"></div>
      </div>
      <div class="container cta-section__inner">
        <div class="cta-section__text">
          <h2 id="cta-heading" class="cta-section__title">¿Listo para mover tu carga?</h2>
          <p class="cta-section__desc">
            Cotiza en 2 minutos · Sin compromisos · Respuesta en menos de 24 h
          </p>
        </div>
        <div class="cta-section__actions">
          <a href="/cotizar" class="cta-section__btn-primary">
            Cotiza ahora
          </a>
          <a href="https://wa.me/56942162739?text=Hola%2C%20me%20interesa%20cotizar" class="cta-section__btn-wa" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.564 4.139 1.543 5.876L0 24l6.324-1.51A11.928 11.928 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-4.997-1.373l-.357-.213-3.753.897.947-3.653-.232-.374A9.773 9.773 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
            Escribir por WhatsApp
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
/* ──────────────────────────────────────────────────────────
   UTILIDADES GLOBALES DE ESTA PÁGINA
────────────────────────────────────────────────────────── */
.container {
  width: 100%;
  max-width: 1280px;
  margin-inline: auto;
  padding-inline: clamp(1.25rem, 5vw, 2.5rem);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-accent-600);
  margin-bottom: 0.875rem;
}
.eyebrow::before {
  content: '';
  display: block;
  width: 24px;
  height: 2px;
  background: var(--color-accent-500);
  flex-shrink: 0;
}

.section-header { text-align: center; margin-bottom: 3.5rem; }

.section-title {
  font-family: var(--font-display);
  font-size: clamp(1.875rem, 4vw, 3rem);
  font-weight: 800;
  line-height: 1.1;
  color: var(--color-neutral-900);
  margin: 0 0 1rem;
}

.section-lead {
  font-size: clamp(1rem, 2vw, 1.125rem);
  color: var(--color-text-muted);
  line-height: 1.65;
  max-width: 560px;
  margin-inline: auto;
}

/* ──────────────────────────────────────────────────────────
   HERO
────────────────────────────────────────────────────────── */
.hero {
  position: relative;
  background: linear-gradient(150deg,
    var(--color-primary-950) 0%,
    var(--color-primary-800) 45%,
    var(--color-primary-600) 100%
  );
  overflow: hidden;
  padding-bottom: 0;
}

/* Decorativos */
.hero__bg { position: absolute; inset: 0; pointer-events: none; }

.hero__blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.25;
}
.hero__blob--1 {
  width: 600px; height: 600px;
  background: var(--color-primary-400);
  top: -200px; right: -150px;
}
.hero__blob--2 {
  width: 400px; height: 400px;
  background: var(--color-accent-500);
  bottom: -100px; left: -100px;
  opacity: 0.15;
}
.hero__grid-lines {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
}

.hero__inner {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2rem, 5vw, 5rem);
  align-items: center;
  padding-top: clamp(4rem, 8vw, 7rem);
  padding-bottom: clamp(4rem, 8vw, 6rem);
}

/* Content */
.hero__content { color: #fff; }

.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--color-primary-200);
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 9999px;
  padding: 0.375rem 1rem;
  margin-bottom: 1.75rem;
  backdrop-filter: blur(8px);
}
.hero__badge-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--color-accent-400);
  box-shadow: 0 0 0 3px rgba(237,140,29,0.3);
  animation: pulse 2s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes pulse {
  0%,100% { box-shadow: 0 0 0 3px rgba(237,140,29,0.3); }
  50%      { box-shadow: 0 0 0 6px rgba(237,140,29,0.1); }
}

.hero__title {
  font-family: var(--font-display);
  font-size: clamp(2.75rem, 6vw, 4.5rem);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.02em;
  color: #ffffff;
  margin: 0 0 1.5rem;
}
.hero__title-gradient {
  display: block;
  background: linear-gradient(90deg, var(--color-accent-300), var(--color-accent-500));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero__lead {
  font-size: clamp(1rem, 2vw, 1.125rem);
  line-height: 1.7;
  color: var(--color-primary-200);
  margin: 0 0 2.25rem;
  max-width: 480px;
}
.hero__lead em { font-style: normal; color: var(--color-accent-300); font-weight: 500; }

.hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 0.875rem;
  margin-bottom: 2rem;
}

.hero__btn-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 1.875rem;
  background: var(--color-cta);
  color: #fff;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.9375rem;
  border-radius: 9999px;
  box-shadow: 0 4px 20px rgba(237,140,29,0.40);
  transition: background 150ms, transform 100ms, box-shadow 150ms;
}
.hero__btn-cta:hover {
  background: var(--color-accent-600);
  transform: translateY(-2px);
  box-shadow: 0 6px 28px rgba(237,140,29,0.50);
}

.hero__btn-wa {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 1.5rem;
  background: rgba(255,255,255,0.08);
  color: #fff;
  font-weight: 600;
  font-size: 0.9375rem;
  border-radius: 9999px;
  border: 1.5px solid rgba(255,255,255,0.2);
  backdrop-filter: blur(8px);
  transition: background 150ms, border-color 150ms;
}
.hero__btn-wa:hover {
  background: rgba(255,255,255,0.15);
  border-color: rgba(255,255,255,0.4);
}

.hero__trust {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.hero__trust-avatars {
  display: flex;
  flex-direction: row-reverse;
}
.hero__trust-avatar {
  display: block;
  width: 32px; height: 32px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.4);
  margin-left: -10px;
}
.hero__trust-avatars .hero__trust-avatar:last-child { margin-left: 0; }
.hero__trust-text {
  font-size: 0.8125rem;
  color: var(--color-primary-300);
  margin: 0;
}

/* Cards flotantes — efecto fanned (Lifecare) */
.hero__cards {
  position: relative;
  height: 380px;
