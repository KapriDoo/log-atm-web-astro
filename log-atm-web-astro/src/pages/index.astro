---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ServicesSection from '../components/sections/ServicesSection.astro';
import WhyVideoSection from '../components/sections/WhyVideoSection.astro';
import IndustriesSection from '../components/sections/IndustriesSection.astro';
import CTASection from '../components/sections/CTASection.astro';
import '../styles/sections.css';
---

<BaseLayout
  title="Logística Aérea y Marítima"
  description="LOG ATM — Soluciones de carga aérea, carga marítima, aduana y almacenaje personalizadas para empresas chilenas. Cotiza ahora."
>
  <Navbar />

  <main id="main-content">
    <HeroSection />
    <ServicesSection />
    <WhyVideoSection />
    <IndustriesSection />
    <CTASection />
  </main>

  <Footer />
</BaseLayout>
