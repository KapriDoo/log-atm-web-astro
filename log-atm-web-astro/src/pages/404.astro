---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe. Vuelve al inicio de LOG ATM."
  noindex={true}
>
  <Navbar />
  <main id="main-content" class="error-page" role="main">
    <div class="error-page__container">
      <span class="error-page__code" aria-hidden="true">404</span>
      <h1 class="error-page__title">Página no encontrada</h1>
      <p class="error-page__lead">
        Lo sentimos, la página que buscas no existe o ha sido movida.
      </p>
      <a href="/" class="error-page__cta">
        Volver al inicio
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .error-page {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .error-page__container {
    max-width: 480px;
  }
  .error-page__code {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 900;
    line-height: 1;
    color: var(--color-primary-200);
    margin-bottom: 1rem;
  }
  .error-page__title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: 0.75rem;
  }
  .error-page__lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .error-page__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-pill);
    background: var(--color-cta);
    color: var(--color-text-inverse);
    font-weight: 600;
    font-size: 1rem;
    transition: background 150ms;
  }
  .error-page__cta:hover {
    background: var(--color-accent-600);
  }
  .error-page__cta:focus-visible {
    outline: 3px solid var(--color-accent-500);
    outline-offset: 3px;
  }
</style>
