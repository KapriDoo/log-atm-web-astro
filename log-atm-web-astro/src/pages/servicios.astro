---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import CTASection from '../components/sections/CTASection.astro';
import { Icon } from 'astro-icon/components';
import { SITE, SERVICES, SERVICE_DETAILS, SERVICE_FILTERS, PROCESS_STEPS, FAQ } from '../lib/constants';
import '../styles/pages/shared.css';
import '../styles/sections/services.css';

const title = 'Servicios';
const description = 'Cobertura logística end-to-end: carga aérea, marítima, aduana OEA, almacenaje, consultoría supply chain y rutas Medio Oriente. 11 soluciones a tu medida.';
const canonical = `${SITE.url}/servicios`;

const detailedServices = SERVICES.filter((s) => SERVICE_DETAILS[s.n as keyof typeof SERVICE_DETAILS]);
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Navbar />

  <main id="main-content">
    <section class="page-hero">
      <div class="container">
        <div class="page-hero__breadcrumb">
          <a href="/">Inicio</a> <span>/</span> <span>Servicios</span>
        </div>
        <div class="page-hero__inner">
          <div>
            <span class="page-hero__eyebrow">Servicios · 11 soluciones</span>
            <h1 class="page-hero__title">Cobertura logística <em>end-to-end</em>.</h1>
            <p class="page-hero__lead">
              Desde el despacho urgente hasta la consultoría de supply chain completa.
              Una sola contraparte, una sola factura, visibilidad total.
            </p>
          </div>
          <div class="page-hero__meta">
            <div class="page-hero__meta-item"><span class="v">11</span><span class="k">Servicios activos</span></div>
            <div class="page-hero__meta-item"><span class="v">70<em>+</em></span><span class="k">Países en red</span></div>
            <div class="page-hero__meta-item"><span class="v">24/7</span><span class="k">Operación</span></div>
            <div class="page-hero__meta-item"><span class="v">OEA</span><span class="k">Aduanas Chile</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="services section" id="servicios">
      <div class="container">
        <div class="svc-filters" role="tablist" aria-label="Categorías de servicios">
          {SERVICE_FILTERS.map((c, i) => (
            <button
              type="button"
              class:list={['svc-filter', { 'svc-filter--active': i === 0 }]}
              data-filter={c.k}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >{c.label}</button>
          ))}
        </div>

        <div class="services__grid">
          {SERVICES.map((s) => (
            <a class:list={[`svc-card`, `svc-card--${s.size}`]} href={s.href}>
              <div class="svc-card__media">
                <img src={s.img} alt={s.title} loading="lazy" decoding="async" />
                <div class="svc-card__overlay"></div>
              </div>
              <span class:list={['svc-card__tag', { 'svc-card__tag--cta': s.isCta }]}>{s.tag}</span>
              <span class="svc-card__icon-pill" aria-hidden="true">
                <Icon name={s.icon} width={18} height={18} />
              </span>
              <div class="svc-card__body">
                <span class="svc-card__num">{s.n} · Servicio</span>
                <h3 class="svc-card__title">{s.title}</h3>
                <p class="svc-card__desc">{s.desc}</p>
                <span class="svc-card__cta">
                  Conocer más
                  <Icon name="lucide:arrow-right" width={14} height={14} aria-hidden="true" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--color-surface);">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Detalle por servicio</span>
          <h2 class="section-head__title" style="margin-top: 0.5rem;">Lo que incluye cada uno</h2>
        </div>
        {detailedServices.map((s, i) => {
          const detail = SERVICE_DETAILS[s.n as keyof typeof SERVICE_DETAILS]!;
          return (
            <div class:list={['svc-detail-row', { 'svc-detail-row--reverse': i % 2 === 1 }]}>
              <div class="svc-detail__media">
                <span class="svc-detail__badge">{detail.badge}</span>
                <img src={s.img} alt={s.title} loading="lazy" />
              </div>
              <div>
                <div class="svc-detail__num">{s.n} · {s.tag}</div>
                <h3 class="svc-detail__title">{s.title}</h3>
                <p class="svc-detail__desc">{s.desc}</p>
                <ul class="svc-detail__features">
                  {detail.features.map((f) => <li>{f}</li>)}
                </ul>
                <a href="/contacto" class="btn btn--brand btn--sm">
                  Cotizar este servicio
                  <Icon name="lucide:arrow-right" width={14} height={14} aria-hidden="true" />
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="process-strip">
      <div class="container">
        <div class="process-strip__head">
          <div>
            <span class="eyebrow" style="color: var(--color-accent-400);">Cómo trabajamos</span>
            <h2 class="process-strip__title" style="margin-top: 0.75rem;">Un proceso predecible en 6 pasos.</h2>
          </div>
          <p class="process-strip__desc">
            De la cotización al cierre con KPIs. Un solo ejecutivo dedicado coordina cada etapa.
          </p>
        </div>
        <div class="process-grid">
          {PROCESS_STEPS.map((p) => (
            <div class="process-step">
              <span class="process-step__n">{p.n}</span>
              <h3 class="process-step__title">{p.title}</h3>
              <p class="process-step__desc">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--color-neutral-50);">
      <div class="container" style="max-width: 900px;">
        <div class="section-head" style="text-align: center;">
          <span class="eyebrow">Preguntas frecuentes</span>
          <h2 class="section-head__title" style="margin-top: 0.5rem;">Resolvemos lo que más nos preguntan</h2>
        </div>
        <div class="faq-list">
          {FAQ.map((f, i) => (
            <details class="faq-item" open={i === 0}>
              <summary>{f.q}</summary>
              <div class="faq-item__body">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CTASection />
  </main>

  <Footer />
</BaseLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('.svc-filter');
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      filters.forEach((b) => {
        b.classList.remove('svc-filter--active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('svc-filter--active');
      btn.setAttribute('aria-selected', 'true');
    });
  });
</script>
