---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import CTASection from '../components/sections/CTASection.astro';
import { Icon } from 'astro-icon/components';
import { SITE, SERVICES } from '../lib/constants';
import { useTranslations, getLangFromUrl, tList } from '../i18n/utils';
import '../styles/pages/shared.css';
import '../styles/sections/services.css';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const title = t('meta.servicios.title');
const description = t('meta.servicios.description');
const canonical = `${SITE.url}/servicios`;

type ServiceCopy = { title: string; desc: string; tag: string };
type ServiceFilter = { k: string; label: string };
type ServiceDetail = { n: string; badge: string; features: string[] };
type FaqItem = { q: string; a: string };
type ProcessStep = { title: string; desc: string };

const serviceCopies = tList<ServiceCopy>(currentLang, 'servicios.list');
const serviceFilters = tList<ServiceFilter>(currentLang, 'servicios.filters');
const serviceDetails = tList<ServiceDetail>(currentLang, 'servicios.details.items');
const processSteps = tList<ProcessStep>(currentLang, 'servicios.process.steps');
const faqItems = tList<FaqItem>(currentLang, 'servicios.faq.items');

const services = SERVICES.map((s, i) => ({ ...s, ...(serviceCopies[i] ?? { title: s.title, desc: s.desc, tag: s.tag }) }));
const detailedServices = services
  .map((s) => {
    const detail = serviceDetails.find((d) => d.n === s.n);
    return detail ? { service: s, detail } : null;
  })
  .filter((x): x is { service: typeof services[number]; detail: ServiceDetail } => x !== null);
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Navbar />

  <main id="main-content">
    <section class="page-hero">
      <div class="container">
        <div class="page-hero__breadcrumb">
          <a href="/">{t('common.breadcrumbHome')}</a> <span>/</span> <span>{t('servicios.breadcrumb')}</span>
        </div>
        <div class="page-hero__inner">
          <div>
            <span class="page-hero__eyebrow">{t('servicios.heroEyebrow')}</span>
            <h1 class="page-hero__title" set:html={t('servicios.heroTitleHtml')}></h1>
            <p class="page-hero__lead">{t('servicios.heroLead')}</p>
          </div>
          <div class="page-hero__meta">
            <div class="page-hero__meta-item"><span class="v">11</span><span class="k">{t('servicios.metaActive')}</span></div>
            <div class="page-hero__meta-item"><span class="v">70<em>+</em></span><span class="k">{t('servicios.metaCountries')}</span></div>
            <div class="page-hero__meta-item"><span class="v">24/7</span><span class="k">{t('servicios.metaOps')}</span></div>
            <div class="page-hero__meta-item"><span class="v">OEA</span><span class="k">{t('servicios.metaCustoms')}</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="services section" id="servicios" aria-labelledby="services-catalog-title">
      <div class="container">
        <h2 id="services-catalog-title" class="sr-only">{t('a11y.servicesCatalog')}</h2>
        <div class="svc-filters" role="tablist" aria-label={t('a11y.serviceCategories')}>
          {serviceFilters.map((c, i) => (
            <button
              type="button"
              class:list={['svc-filter', { 'svc-filter--active': i === 0 }]}
              data-filter={c.k}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >{c.label}</button>
          ))}
        </div>

        <div class="services__grid">
          {services.map((s) => (
            <a class:list={[`svc-card`, `svc-card--${s.size}`]} href={s.href}>
              <div class="svc-card__media">
                <img src={s.img} alt={s.title} loading="lazy" decoding="async" />
                <div class="svc-card__overlay"></div>
              </div>
              <span class:list={['svc-card__tag', { 'svc-card__tag--cta': s.isCta }]}>{s.tag}</span>
              <span class="svc-card__icon-pill" aria-hidden="true">
                <Icon name={s.icon} width={18} height={18} />
              </span>
              <div class="svc-card__body">
                <span class="svc-card__num">{s.n} · {t('home.services.numPrefix')}</span>
                <h3 class="svc-card__title">{s.title}</h3>
                <p class="svc-card__desc">{s.desc}</p>
                <span class="svc-card__cta">
                  {t('common.learnMore')}
                  <Icon name="lucide:arrow-right" width={14} height={14} aria-hidden="true" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--surface">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">{t('servicios.details.sectionEyebrow')}</span>
          <h2 class="section-head__title">{t('servicios.details.sectionTitle')}</h2>
        </div>
        {detailedServices.map(({ service: s, detail }, i) => (
          <div class:list={['svc-detail-row', { 'svc-detail-row--reverse': i % 2 === 1 }]}>
            <div class="svc-detail__media">
              <span class="svc-detail__badge">{detail.badge}</span>
              <img src={s.img} alt={s.title} loading="lazy" />
            </div>
            <div>
              <div class="svc-detail__num">{s.n} · {s.tag}</div>
              <h3 class="svc-detail__title">{s.title}</h3>
              <p class="svc-detail__desc">{s.desc}</p>
              <ul class="svc-detail__features">
                {detail.features.map((f) => <li>{f}</li>)}
              </ul>
              <a href="/contacto" class="btn btn--brand btn--sm">
                {t('servicios.details.cardCta')}
                <Icon name="lucide:arrow-right" width={14} height={14} aria-hidden="true" />
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="process-strip">
      <div class="container">
        <div class="process-strip__head">
          <div>
            <span class="eyebrow">{t('servicios.process.eyebrow')}</span>
            <h2 class="process-strip__title">{t('servicios.process.title')}</h2>
          </div>
          <p class="process-strip__desc">{t('servicios.process.desc')}</p>
        </div>
        <div class="process-grid">
          {processSteps.map((p, i) => (
            <div class="process-step">
              <span class="process-step__n">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="process-step__title">{p.title}</h3>
              <p class="process-step__desc">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--alt section--narrow">
      <div class="container">
        <div class="section-head section-head--centered">
          <span class="eyebrow">{t('servicios.faq.eyebrow')}</span>
          <h2 class="section-head__title">{t('servicios.faq.title')}</h2>
        </div>
        <div class="faq-list">
          {faqItems.map((f, i) => (
            <details class="faq-item" open={i === 0}>
              <summary>{f.q}</summary>
              <div class="faq-item__body">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CTASection />
  </main>

  <Footer />
</BaseLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('.svc-filter');
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      filters.forEach((b) => {
        b.classList.remove('svc-filter--active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('svc-filter--active');
      btn.setAttribute('aria-selected', 'true');
    });
  });
</script>
