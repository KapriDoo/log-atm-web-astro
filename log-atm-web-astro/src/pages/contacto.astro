---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from '../lib/constants';
import '../styles/pages/shared.css';

const title = 'Contacto';
const description = 'Hablemos de tu próximo envío. Respuesta en menos de 24 horas hábiles con tu ejecutivo dedicado. WhatsApp, teléfono o email — Vitacura, Santiago.';
const canonical = `${SITE.url}/contacto`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Navbar />

  <main id="main-content">
    <section class="page-hero">
      <div class="container">
        <div class="page-hero__breadcrumb">
          <a href="/">Inicio</a> <span>/</span> <span>Contacto</span>
        </div>
        <div class="page-hero__inner">
          <div>
            <span class="page-hero__eyebrow">Contacto · Respuesta en 24h</span>
            <h1 class="page-hero__title">
              Hablemos de tu <em>próximo envío</em>.
            </h1>
            <p class="page-hero__lead">
              Cuéntanos qué necesitas mover. Un ejecutivo dedicado te responde con una
              propuesta clara, en menos de 24 horas hábiles.
            </p>
          </div>
          <div class="page-hero__meta">
            <div class="page-hero__meta-item"><span class="v">24<em>h</em></span><span class="k">Tiempo de respuesta</span></div>
            <div class="page-hero__meta-item"><span class="v">1:1</span><span class="k">Ejecutivo dedicado</span></div>
            <div class="page-hero__meta-item"><span class="v">24/7</span><span class="k">Soporte operativo</span></div>
            <div class="page-hero__meta-item"><span class="v">CL</span><span class="k">Santiago, Vitacura</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <div class="contact-grid">
          <form class="contact-form-card" id="contact-form" novalidate>
            <div class="contact-form-card__head">
              <div>
                <h2 class="contact-form-card__title">Cuéntanos qué necesitas mover</h2>
                <p class="contact-form-card__sub">Respondemos en menos de 24h hábiles · sin spam.</p>
              </div>
              <span class="contact-form-card__pill">En línea ahora</span>
            </div>

            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="cn">Nombre</label>
                <input id="cn" name="name" type="text" placeholder="Tu nombre" autocomplete="name" required />
              </div>
              <div class="form-field">
                <label for="ce">Empresa</label>
                <input id="ce" name="company" type="text" placeholder="Razón social" autocomplete="organization" />
              </div>
            </div>

            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="cm">Email</label>
                <input id="cm" name="email" type="email" placeholder="nombre@empresa.cl" autocomplete="email" required />
              </div>
              <div class="form-field">
                <label for="cp">Teléfono</label>
                <input id="cp" name="phone" type="tel" placeholder="+56 9 ..." autocomplete="tel" />
              </div>
            </div>

            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="cs">Servicio</label>
                <select id="cs" name="service">
                  <option>Carga Marítima · FCL</option>
                  <option>Carga Marítima · LCL</option>
                  <option>Carga Aérea / Courier</option>
                  <option>Aduana y Documentación</option>
                  <option>Almacenaje · Fulfillment</option>
                  <option>Consultoría Supply Chain</option>
                  <option>Otro · cuéntanos</option>
                </select>
              </div>
              <div class="form-field">
                <label for="co">Origen → Destino</label>
                <input id="co" name="route" type="text" placeholder="Ej. Shanghai → Santiago" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label for="cmsg">Mensaje</label>
                <textarea id="cmsg" name="message" placeholder="Cuéntanos volumen, plazos, tipo de carga..."></textarea>
              </div>
            </div>

            <button class="form-submit" type="submit" id="contact-submit">
              <span class="form-submit__label">Enviar solicitud</span>
              <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
            </button>
            <p class="form-fineprint">
              Al enviar aceptas nuestra <a href="#">política de privacidad</a>. No compartimos tus datos.
            </p>
          </form>

          <div>
            <span class="eyebrow">Canales directos</span>

            <div class="contact-channels">
              <a class="channel channel--wa" href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">
                <div class="channel__icon">
                  <Icon name="lucide:message-circle" width={22} height={22} aria-hidden="true" />
                </div>
                <div>
                  <div class="channel__name">WhatsApp · respuesta inmediata</div>
                  <div class="channel__value">{SITE.phoneDisplay}</div>
                </div>
                <span class="channel__arrow" aria-hidden="true">→</span>
              </a>
              <a class="channel" href={`tel:${SITE.phone}`}>
                <div class="channel__icon">
                  <Icon name="lucide:phone" width={20} height={20} aria-hidden="true" />
                </div>
                <div>
                  <div class="channel__name">Teléfono</div>
                  <div class="channel__value">{SITE.phoneDisplay}</div>
                </div>
                <span class="channel__arrow" aria-hidden="true">→</span>
              </a>
              <a class="channel" href={`mailto:${SITE.email}`}>
                <div class="channel__icon">
                  <Icon name="lucide:mail" width={20} height={20} aria-hidden="true" />
                </div>
                <div>
                  <div class="channel__name">Email · operaciones</div>
                  <div class="channel__value">{SITE.email}</div>
                </div>
                <span class="channel__arrow" aria-hidden="true">→</span>
              </a>
            </div>

            <div class="office-card">
              <div class="office-card__map" aria-hidden="true">
                <div class="office-card__map-grid"></div>
                <div class="office-card__pin"></div>
              </div>
              <div class="office-card__body">
                <h3 class="office-card__name">Oficina Santiago</h3>
                <p class="office-card__address">{SITE.address}</p>
                <div class="office-card__hours">
                  <div class="office-card__hours-row"><span>Lun – Vie</span><strong>09:00 – 18:30</strong></div>
                  <div class="office-card__hours-row"><span>Sábado</span><strong>10:00 – 13:00</strong></div>
                  <div class="office-card__hours-row"><span>Soporte op.</span><strong>24/7</strong></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const form  = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn   = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const label = btn?.querySelector<HTMLSpanElement>('.form-submit__label');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!btn || !label) return;
    btn.disabled = true;
    label.textContent = '✓ Recibido — te contactamos hoy';
    btn.querySelector('svg')?.remove();
  });
</script>
