---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import Icon from "../components/ui/Icon.astro";
import { SITE } from '../lib/constants';
import { useTranslations, getLangFromUrl, tList, type Locale } from '../i18n/utils';
import WhatsAppIcon from '../components/icons/WhatsAppIcon.astro';
import '../styles/pages/shared.css';

const { lang: langProp } = Astro.props as { lang?: Locale };
const currentLang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const title = t('meta.contacto.title');
const description = t('meta.contacto.description');

const formServices = tList<string>(currentLang, 'contacto.form.services');
const submitSuccessText = t('contacto.form.submitSuccess');
---

<BaseLayout title={title} description={description} lang={currentLang}>
  <Navbar />

  <main id="main-content">
    <section class="page-hero">
      <div class="container">
        <div class="page-hero__breadcrumb">
          <a href="/">{t('common.breadcrumbHome')}</a> <span>/</span> <span>{t('contacto.breadcrumb')}</span>
        </div>
        <div class="page-hero__inner">
          <div>
            <span class="page-hero__eyebrow" data-hero-animate>{t('contacto.heroEyebrow')}</span>
            <h1 class="page-hero__title" set:html={t('contacto.heroTitleHtml')} data-hero-animate></h1>
            <p class="page-hero__lead" data-hero-animate>{t('contacto.heroLead')}</p>
          </div>
          <div class="page-hero__meta">
            <div class="page-hero__meta-item" data-hero-animate><span class="v">24<em>h</em></span><span class="k">{t('contacto.metaResponse')}</span></div>
            <div class="page-hero__meta-item" data-hero-animate><span class="v">1:1</span><span class="k">{t('contacto.metaExec')}</span></div>
            <div class="page-hero__meta-item" data-hero-animate><span class="v">24/7</span><span class="k">{t('contacto.metaSupport')}</span></div>
            <div class="page-hero__meta-item" data-hero-animate><span class="v">CL</span><span class="k">{t('contacto.metaOffice')}</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <div class="contact-grid">
          <form
            class="contact-form-card"
            id="contact-form"
            novalidate
            data-success={submitSuccessText}
            data-msg-sending={t('contacto.form.sending')}
            data-msg-sent={t('contacto.form.sent')}
            data-msg-sent-label={t('contacto.form.sentLabel')}
            data-msg-review-prefix={t('contacto.form.reviewPrefix')}
            data-msg-send-fail={t('contacto.form.sendFail')}
            data-msg-conn-error={t('contacto.form.connError')}
          >
            {/* Honeypot anti-spam (no tocar) */}
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;"
            />
            <div class="contact-form-card__head">
              <div>
                <h2 class="contact-form-card__title">{t('contacto.form.title')}</h2>
                <p class="contact-form-card__sub">{t('contacto.form.sub')}</p>
              </div>
              <span class="contact-form-card__pill">{t('contacto.form.pill')}</span>
            </div>

            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="cn">{t('contacto.form.labelName')}</label>
                <input id="cn" name="name" type="text" placeholder={t('contacto.form.placeholderName')} autocomplete="name" required />
              </div>
              <div class="form-field">
                <label for="ce">{t('contacto.form.labelCompany')}</label>
                <input id="ce" name="company" type="text" placeholder={t('contacto.form.placeholderCompany')} autocomplete="organization" />
              </div>
            </div>

            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="cm">{t('contacto.form.labelEmail')}</label>
                <input id="cm" name="email" type="email" placeholder={t('contacto.form.placeholderEmail')} autocomplete="email" required />
              </div>
              <div class="form-field">
                <label for="cp">{t('contacto.form.labelPhone')}</label>
                <input id="cp" name="phone" type="tel" placeholder={t('contacto.form.placeholderPhone')} autocomplete="tel" />
              </div>
            </div>

            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="cs">{t('contacto.form.labelService')}</label>
                <select id="cs" name="service">
                  {formServices.map((s) => <option>{s}</option>)}
                </select>
              </div>
              <div class="form-field">
                <label for="co">{t('contacto.form.labelRoute')}</label>
                <input id="co" name="route" type="text" placeholder={t('contacto.form.placeholderRoute')} />
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label for="cmsg">{t('contacto.form.labelMessage')}</label>
                <textarea id="cmsg" name="message" placeholder={t('contacto.form.placeholderMessage')}></textarea>
              </div>
            </div>

            <button class="form-submit" type="submit" id="contact-submit">
              <span class="form-submit__label">{t('contacto.form.submit')}</span>
              <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
            </button>
            <p
              class="form-status"
              id="contact-status"
              role="status"
              aria-live="polite"
              aria-atomic="true"
              style="margin:0.5rem 0 0;font-size:0.875rem;min-height:1.25rem;"
            ></p>
            <p class="form-fineprint" set:html={t('contacto.form.fineprintHtml')}></p>
          </form>

          <div>
            <span class="eyebrow">{t('contacto.channels.eyebrow')}</span>

            <div class="contact-channels">
              <a class="channel channel--wa" href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">
                <span class="channel__icon">
                  <WhatsAppIcon width={22} height={22} ariaLabel="WhatsApp" />
                </span>
                <div>
                  <div class="channel__name">{t('contacto.channels.whatsappName')}</div>
                  <div class="channel__value">{SITE.phoneDisplay}</div>
                </div>
                <span class="channel__arrow" aria-hidden="true">→</span>
              </a>
              <a class="channel" href={`tel:${SITE.phone}`}>
                <div class="channel__icon">
                  <Icon name="lucide:phone" width={20} height={20} aria-hidden="true" />
                </div>
                <div>
                  <div class="channel__name">{t('contacto.channels.phoneName')}</div>
                  <div class="channel__value">{SITE.phoneDisplay}</div>
                </div>
                <span class="channel__arrow" aria-hidden="true">→</span>
              </a>
              <a class="channel" href={`mailto:${SITE.email}`}>
                <div class="channel__icon">
                  <Icon name="lucide:mail" width={20} height={20} aria-hidden="true" />
                </div>
                <div>
                  <div class="channel__name">{t('contacto.channels.emailName')}</div>
                  <div class="channel__value">{SITE.email}</div>
                </div>
                <span class="channel__arrow" aria-hidden="true">→</span>
              </a>
            </div>

            <div class="office-card">
              <div class="office-card__map" aria-hidden="true">
                <div class="office-card__map-grid"></div>
                <div class="office-card__pin"></div>
              </div>
              <div class="office-card__body">
                <h3 class="office-card__name">{t('contacto.office.name')}</h3>
                <p class="office-card__address">{SITE.address}</p>
                <div class="office-card__hours">
                  <div class="office-card__hours-row"><span>{t('contacto.office.rowWeek')}</span><strong>{t('contacto.office.hoursWeek')}</strong></div>
                  <div class="office-card__hours-row"><span>{t('contacto.office.rowSat')}</span><strong>{t('contacto.office.hoursSat')}</strong></div>
                  <div class="office-card__hours-row"><span>{t('contacto.office.rowSupport')}</span><strong>{t('contacto.office.hoursSupport')}</strong></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Envuelto en astro:page-load para que los listeners sobrevivan View Transitions
  document.addEventListener('astro:page-load', () => {
    const controller = new AbortController();
    document.addEventListener('astro:before-swap', () => controller.abort(), { once: true });

    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const btn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const label = btn?.querySelector<HTMLSpanElement>('.form-submit__label');
    const successText = form?.dataset.success ?? '';
    const MSG = {
      sending:      form?.dataset.msgSending      ?? 'Enviando tu mensaje…',
      sent:         form?.dataset.msgSent         ?? successText,
      sentLabel:    form?.dataset.msgSentLabel    ?? '✓ Enviado',
      reviewPrefix: form?.dataset.msgReviewPrefix ?? 'Revisa los datos:',
      sendFail:     form?.dataset.msgSendFail     ?? 'No pudimos enviar tu mensaje. Reintenta o escríbenos por WhatsApp.',
      connError:    form?.dataset.msgConnError    ?? 'Error de conexión. Reintenta en unos segundos.',
    };
    const status = document.getElementById('contact-status') as HTMLElement | null;

    function setStatus(msg: string, kind: '' | 'error' | 'success' = '') {
      if (!status) return;
      status.textContent = msg;
      status.style.color =
        kind === 'error' ? '#c0392b' : kind === 'success' ? '#2d9b6f' : '';
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form || !btn || !label) return;

      const original = label.textContent ?? 'Enviar solicitud';
      btn.disabled = true;
      label.textContent = MSG.sending;
      setStatus(MSG.sending);

      const fd = new FormData(form);
      const payload: Record<string, string> = {};
      fd.forEach((v, k) => { payload[k] = String(v); });

      try {
        const r = await fetch('/api/contacto', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok && data.ok) {
          setStatus(MSG.sent, 'success');
          label.textContent = MSG.sentLabel;
          btn.querySelector('svg')?.remove();
          form.reset();
          return;
        }
        if (r.status === 400 && data.fields) {
          const first = Object.values(data.fields)[0] as string;
          setStatus(`${MSG.reviewPrefix} ${first}`, 'error');
        } else {
          setStatus(MSG.sendFail, 'error');
        }
        label.textContent = original;
        btn.disabled = false;
      } catch {
        setStatus(MSG.connError, 'error');
        label.textContent = original;
        btn.disabled = false;
      }
    }, { signal: controller.signal });
  });
</script>
