---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from '../lib/constants';

const title = 'Contacto';
const description = 'Contáctanos para cotizar tu envío internacional. Atención personalizada 24/7 vía WhatsApp, email o teléfono.';
const canonical = `${SITE.url}/contacto`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Navbar />

  <main id="main-content">
    <!-- Hero -->
    <section class="page-hero" aria-labelledby="page-title">
      <div class="container page-hero__inner">
        <span class="eyebrow">Contacto</span>
        <h1 id="page-title" class="page-hero__title">Hablemos de tu carga</h1>
        <p class="page-hero__lead">
          Estamos aquí para ayudarte. Cotiza tu envío o haz cualquier consulta.
        </p>
      </div>
    </section>

    <!-- Contact Grid -->
    <section class="contact-section" aria-labelledby="contact-title">
      <div class="container">
        <div class="contact-grid">
          <!-- Info -->
          <div class="contact-info">
            <h2 id="contact-title" class="contact-info__title">Información de contacto</h2>
            
            <div class="contact-method">
              <div class="contact-method__icon" aria-hidden="true">
                <Icon name="lucide:phone" width="24" height="24" />
              </div>
              <div>
                <strong>Teléfono</strong>
                <a href={`tel:${SITE.phone}`}>{SITE.phone}</a>
              </div>
            </div>

            <div class="contact-method">
              <div class="contact-method__icon" aria-hidden="true">
                <Icon name="lucide:mail" width="24" height="24" />
              </div>
              <div>
                <strong>Email</strong>
                <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
              </div>
            </div>

            <div class="contact-method">
              <div class="contact-method__icon" aria-hidden="true">
                <Icon name="lucide:map-pin" width="24" height="24" />
              </div>
              <div>
                <strong>Dirección</strong>
                <span>{SITE.address}</span>
              </div>
            </div>

            <a href={SITE.whatsappUrl} class="contact-whatsapp" target="_blank" rel="noopener noreferrer">
              <Icon name="lucide:message-circle" width="20" height="20" />
              Escríbenos por WhatsApp
            </a>
          </div>

          <!-- Form -->
          <div class="contact-form-wrap">
            <h2 class="contact-form__title">Envíanos un mensaje</h2>
            <form class="contact-form" action="#" method="POST" aria-label="Formulario de contacto">
              <div class="form-group">
                <label for="name">Nombre completo *</label>
                <input type="text" id="name" name="name" required placeholder="Tu nombre" />
              </div>

              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required placeholder="tu@email.com" />
              </div>

              <div class="form-group">
                <label for="company">Empresa</label>
                <input type="text" id="company" name="company" placeholder="Nombre de tu empresa" />
              </div>

              <div class="form-group">
                <label for="service">Servicio de interés</label>
                <select id="service" name="service">
                  <option value="">Selecciona un servicio</option>
                  <option value="carga-aerea">Carga Aérea</option>
                  <option value="carga-maritima">Carga Marítima</option>
                  <option value="aduanas">Aduana y Documentación</option>
                  <option value="almacenaje">Almacenaje</option>
                  <option value="consultoria">Consultoría Logística</option>
                </select>
              </div>

              <div class="form-group">
                <label for="message">Mensaje *</label>
                <textarea id="message" name="message" rows="4" required placeholder="Cuéntanos sobre tu envío..."></textarea>
              </div>

              <button type="submit" class="btn-submit">
                Enviar mensaje
                <Icon name="lucide:send" width="16" height="16" />
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* .page-hero, .page-hero__* → global.css */

  .contact-section {
    padding: clamp(4rem, 8vw, 6rem) 0;
    background: var(--color-bg);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
  }

  .contact-info__title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 2rem;
    color: var(--color-neutral-900);
  }
  .contact-method {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .contact-method__icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    background: var(--color-primary-50);
    color: var(--color-brand);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .contact-method strong {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
  .contact-method a {
    color: var(--color-neutral-900);
    font-weight: 600;
    font-size: 1.1rem;
  }
  .contact-method span {
    color: var(--color-neutral-900);
    font-size: 1.1rem;
  }

  .contact-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.5rem;
    border-radius: 9999px;
    background: #128C7E;
    color: var(--color-text-inverse);
    font-weight: 600;
    margin-top: 1rem;
    transition: background 150ms;
  }
  .contact-whatsapp:hover { background: #0d6b61; }

  .contact-form-wrap {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2.5rem;
  }
  .contact-form__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    color: var(--color-neutral-900);
  }
  .form-group {
    margin-bottom: 1.25rem;
  }
  .form-group label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-neutral-700);
    margin-bottom: 0.375rem;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-neutral-200);
    border-radius: 10px;
    font-size: 1rem;
    color: var(--color-neutral-900);
    background: var(--color-surface);
    transition: border-color 150ms, box-shadow 150ms;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px rgba(74, 123, 181, 0.1);
  }
  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    justify-content: center;
    padding: 0.875rem;
    border-radius: 9999px;
    background: var(--color-cta);
    color: var(--color-text-inverse);
    font-weight: 700;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: background 150ms;
  }
  .btn-submit:hover { background: var(--color-accent-600); }
</style>
