---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from '../lib/constants';

const title = 'Cotizar';
const description = 'Cotiza tu envío internacional en 2 minutos. Carga aérea, marítima y servicios aduaneros. Respuesta en menos de 24 horas.';
const canonical = `${SITE.url}/cotizar`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Navbar />

  <main id="main-content">
    <!-- Hero -->
    <section class="page-hero" aria-labelledby="page-title">
      <div class="container page-hero__inner">
        <span class="eyebrow">Cotización</span>
        <h1 id="page-title" class="page-hero__title">Cotiza tu envío</h1>
        <p class="page-hero__lead">
          Completa el formulario y recibe una propuesta en menos de 24 horas.
          Sin compromisos.
        </p>
      </div>
    </section>

    <!-- Form Section -->
    <section class="quote-section" aria-labelledby="form-title">
      <div class="container">
        <div class="quote-grid">
          <!-- Info sidebar -->
          <div class="quote-info">
            <h2 id="form-title" class="quote-info__title">¿Qué necesitas?</h2>
            
            <ul class="quote-features" role="list">
              <li>
                <Icon name="lucide:clock" width="20" height="20" />
                Respuesta en 24h
              </li>
              <li>
                <Icon name="lucide:shield-check" width="20" height="20" />
                Sin compromisos
              </li>
              <li>
                <Icon name="lucide:tag" width="20" height="20" />
                Mejor precio garantizado
              </li>
              <li>
                <Icon name="lucide:headphones" width="20" height="20" />
                Ejecutivo dedicado
              </li>
            </ul>

            <div class="quote-contact">
              <strong>¿Prefieres hablar directo?</strong>
              <a href={SITE.whatsappUrl} class="quote-whatsapp" target="_blank" rel="noopener noreferrer">
                <Icon name="lucide:message-circle" width="18" height="18" />
                WhatsApp: {SITE.phone}
              </a>
            </div>
          </div>

          <!-- Form -->
          <div class="quote-form-wrap">
            <form class="quote-form" action="#" method="POST" aria-label="Formulario de cotización">
              <div class="form-row">
                <div class="form-group">
                  <label for="quote-name">Nombre completo *</label>
                  <input type="text" id="quote-name" name="name" required placeholder="Tu nombre" />
                </div>
                <div class="form-group">
                  <label for="quote-email">Email *</label>
                  <input type="email" id="quote-email" name="email" required placeholder="tu@email.com" />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="quote-company">Empresa</label>
                  <input type="text" id="quote-company" name="company" placeholder="Nombre de tu empresa" />
                </div>
                <div class="form-group">
                  <label for="quote-phone">Teléfono</label>
                  <input type="tel" id="quote-phone" name="phone" placeholder="+56 9 1234 5678" />
                </div>
              </div>

              <div class="form-group">
                <label for="quote-service">Tipo de servicio *</label>
                <select id="quote-service" name="service" required>
                  <option value="">Selecciona un servicio</option>
                  <option value="carga-aerea">Carga Aérea</option>
                  <option value="carga-maritima">Carga Marítima</option>
                  <option value="aduanas">Aduana y Documentación</option>
                  <option value="almacenaje">Almacenaje</option>
                  <option value="consultoria">Consultoría Logística</option>
                </select>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="quote-origin">Origen</label>
                  <input type="text" id="quote-origin" name="origin" placeholder="Ciudad, País" />
                </div>
                <div class="form-group">
                  <label for="quote-destination">Destino</label>
                  <input type="text" id="quote-destination" name="destination" placeholder="Ciudad, País" />
                </div>
              </div>

              <div class="form-group">
                <label for="quote-details">Detalles de la carga *</label>
                <textarea id="quote-details" name="details" rows="4" required placeholder="Tipo de mercancía, peso, dimensiones, cantidad..."></textarea>
              </div>

              <button type="submit" class="btn-submit">
                Solicitar cotización
                <Icon name="lucide:send" width="16" height="16" />
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* .page-hero, .page-hero__* → global.css */

  .quote-section {
    padding: clamp(4rem, 8vw, 6rem) 0;
    background: var(--color-bg);
  }
  .quote-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .quote-grid { grid-template-columns: 1fr; gap: 3rem; }
  }

  .quote-info__title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    color: var(--color-neutral-900);
  }
  .quote-features {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
  }
  .quote-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    color: var(--color-neutral-700);
    border-bottom: 1px solid var(--color-border);
  }
  .quote-features li:last-child { border-bottom: none; }
  .quote-features :global(svg) {
    color: var(--color-brand);
    flex-shrink: 0;
  }

  .quote-contact {
    background: var(--color-primary-50);
    border-radius: var(--radius-card);
    padding: 1.5rem;
  }
  .quote-contact strong {
    display: block;
    margin-bottom: 0.75rem;
    color: var(--color-neutral-900);
  }
  .quote-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-pill);
    background: var(--color-whatsapp);
    color: var(--color-text-inverse);
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 150ms;
  }
  .quote-whatsapp:hover { background: var(--color-whatsapp-hover-dark); }

  .quote-form-wrap {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }
  .form-group {
    margin-bottom: 1.25rem;
  }
  .form-group label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-neutral-700);
    margin-bottom: 0.375rem;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-input);
    font-size: 1rem;
    color: var(--color-neutral-900);
    background: var(--color-surface);
    transition: border-color 150ms, box-shadow 150ms;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary-500) 10%, transparent);
  }
  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    justify-content: center;
    padding: 0.875rem;
    border-radius: var(--radius-pill);
    background: var(--color-cta);
    color: var(--color-text-inverse);
    font-weight: 700;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: background 150ms;
  }
  .btn-submit:hover { background: var(--color-accent-600); }
</style>
