---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import { Icon } from 'astro-icon/components';
import {
  SITE,
  QUOTE_MODES,
  QUOTE_ORIGINS,
  QUOTE_DESTS,
  QUOTE_CARGO_TYPES,
  QUOTE_EXTRAS,
  QUOTE_STEPS,
} from '../lib/constants';
import '../styles/pages/shared.css';
import '../styles/pages/cotizar.css';

const title = 'Cotizar';
const description = 'Cotiza tu envío internacional en 4 pasos. Modalidad, ruta, carga y contacto — propuesta clara en menos de 24h hábiles con tu ejecutivo dedicado.';
const canonical = `${SITE.url}/cotizar`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <Navbar />

  <main id="main-content">
    <section class="quote-hero">
      <div class="container quote-hero__inner">
        <div>
          <div class="page-hero__breadcrumb">
            <a href="/">Inicio</a> <span>/</span> <span>Cotizar</span>
          </div>
          <h1 class="quote-hero__title">
            Cotiza en <em>4 pasos</em>.
          </h1>
          <p class="quote-hero__lead">
            Recibe una propuesta clara y desglosada en menos de 24 horas hábiles,
            con tu ejecutivo dedicado asignado.
          </p>
        </div>
        <div class="quote-hero__chips">
          <span class="quote-chip">Respuesta &lt; 24h</span>
          <span class="quote-chip">Sin compromiso</span>
          <span class="quote-chip">Ejecutivo 1:1</span>
        </div>
      </div>
    </section>

    <div class="stepper" id="stepper">
      <div class="container">
        <div class="stepper__track">
          {QUOTE_STEPS.map((s, i) => (
            <div
              class:list={['stepper__step', { 'stepper__step--active': i === 0 }]}
              data-step={i}
            >
              <div class="stepper__bullet">{s.n}</div>
              <div class="stepper__meta">
                <span class="stepper__label">Paso {s.n}</span>
                <span class="stepper__name">{s.name}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <section style="background: var(--color-neutral-50);">
      <div class="container quote-layout">
        <!-- Wizard card -->
        <div class="quote-card" id="quote-card">
          <!-- Step 0: Modalidad -->
          <div class="quote-step" data-step-panel="0">
            <div class="quote-step__head">
              <div class="quote-step__num">Paso 01 · Modalidad</div>
              <h2 class="quote-step__title">¿Cómo movemos tu carga?</h2>
              <p class="quote-step__sub">Si no estás seguro, elige una y lo ajustamos en la propuesta.</p>
            </div>
            <div class="mode-grid">
              {QUOTE_MODES.map((m) => (
                <button
                  class="mode-tile"
                  type="button"
                  data-mode={m.k}
                  data-mode-name={m.name}
                >
                  <div class="mode-tile__icon">
                    <Icon name={m.icon} width={22} height={22} aria-hidden="true" />
                  </div>
                  <div>
                    <h3 class="mode-tile__name">{m.name}</h3>
                    <p class="mode-tile__desc">{m.desc}</p>
                  </div>
                  <div class="mode-tile__check">✓</div>
                </button>
              ))}
            </div>
          </div>

          <!-- Step 1: Ruta -->
          <div class="quote-step" data-step-panel="1" hidden>
            <div class="quote-step__head">
              <div class="quote-step__num">Paso 02 · Ruta</div>
              <h2 class="quote-step__title">¿De dónde a dónde?</h2>
              <p class="quote-step__sub">Si tu origen no aparece, escríbelo en notas más adelante.</p>
            </div>
            <div class="route-pair">
              <div class="form-field">
                <label for="q-origin">Origen</label>
                <select id="q-origin" name="origin">
                  <option value="">Selecciona origen...</option>
                  {QUOTE_ORIGINS.map((o) => <option value={o}>{o}</option>)}
                </select>
              </div>
              <div class="route-pair__arrow" aria-hidden="true">→</div>
              <div class="form-field">
                <label for="q-dest">Destino</label>
                <select id="q-dest" name="dest">
                  {QUOTE_DESTS.map((d, i) => <option value={d} selected={i === 0}>{d}</option>)}
                </select>
              </div>
            </div>
            <div class="form-row form-row--2" style="margin-top: 1.5rem;">
              <div class="form-field">
                <label for="q-incoterm">Incoterm</label>
                <select id="q-incoterm" name="incoterm">
                  <option>FOB</option>
                  <option>CIF</option>
                  <option>EXW</option>
                  <option>DAP</option>
                  <option>DDP</option>
                  <option>No estoy seguro</option>
                </select>
              </div>
              <div class="form-field">
                <label for="q-date">Fecha estimada de salida</label>
                <input id="q-date" name="date" type="month" />
              </div>
            </div>
          </div>

          <!-- Step 2: Carga -->
          <div class="quote-step" data-step-panel="2" hidden>
            <div class="quote-step__head">
              <div class="quote-step__num">Paso 03 · Carga</div>
              <h2 class="quote-step__title">¿Qué vamos a mover?</h2>
              <p class="quote-step__sub">Marca todos los tipos que apliquen — pueden combinarse.</p>
            </div>

            <div class="form-field" style="margin-bottom: 1.5rem;">
              <label>Tipo de carga</label>
              <div class="chips-multi" id="cargo-chips">
                {QUOTE_CARGO_TYPES.map((c) => (
                  <button type="button" class="chip-multi" data-cargo={c}>{c}</button>
                ))}
              </div>
            </div>

            <div class="form-field" style="margin-bottom: 0.5rem;">
              <label>Volumen / dimensiones</label>
              <div class="unit-toggle" id="unit-toggle">
                <button type="button" class="unit-toggle__btn unit-toggle__btn--active" data-unit="cbm">m³ / kg</button>
                <button type="button" class="unit-toggle__btn" data-unit="fcl20">20' FCL</button>
                <button type="button" class="unit-toggle__btn" data-unit="fcl40">40' FCL</button>
              </div>
            </div>

            <div id="cbm-fields" class="form-row form-row--2">
              <div class="form-field">
                <label for="q-volume">Volumen (m³)</label>
                <input id="q-volume" name="volume" type="number" min="0" step="0.1" placeholder="Ej. 12.5" />
              </div>
              <div class="form-field">
                <label for="q-weight">Peso bruto (kg)</label>
                <input id="q-weight" name="weight" type="number" min="0" placeholder="Ej. 3500" />
              </div>
            </div>
            <div id="fcl-fields" class="form-field" hidden>
              <label for="q-count">Cantidad de contenedores</label>
              <input id="q-count" name="containerCount" type="number" min="1" placeholder="Ej. 2" />
            </div>

            <div class="form-field" style="margin-top: 1.5rem;">
              <label>Servicios adicionales</label>
              <div class="chips-multi" id="extras-chips">
                {QUOTE_EXTRAS.map((s) => (
                  <button type="button" class="chip-multi" data-extra={s}>{s}</button>
                ))}
              </div>
            </div>
          </div>

          <!-- Step 3: Contacto -->
          <div class="quote-step" data-step-panel="3" hidden>
            <div class="quote-step__head">
              <div class="quote-step__num">Paso 04 · Contacto</div>
              <h2 class="quote-step__title">¿A quién enviamos la propuesta?</h2>
              <p class="quote-step__sub">Te responde un ejecutivo dedicado, no un bot.</p>
            </div>
            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="q-name">Nombre completo</label>
                <input id="q-name" name="name" type="text" autocomplete="name" placeholder="Tu nombre" required />
              </div>
              <div class="form-field">
                <label for="q-company">Empresa</label>
                <input id="q-company" name="company" type="text" autocomplete="organization" placeholder="Razón social" />
              </div>
            </div>
            <div class="form-row form-row--2">
              <div class="form-field">
                <label for="q-email">Email</label>
                <input id="q-email" name="email" type="email" autocomplete="email" placeholder="nombre@empresa.cl" required />
              </div>
              <div class="form-field">
                <label for="q-phone">Teléfono / WhatsApp</label>
                <input id="q-phone" name="phone" type="tel" autocomplete="tel" placeholder="+56 9 ..." />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field">
                <label for="q-notes">Notas adicionales (opcional)</label>
                <textarea id="q-notes" name="notes" placeholder="Detalles del producto, plazos críticos, requisitos especiales..."></textarea>
              </div>
            </div>
          </div>

          <div class="quote-nav">
            <button class="btn-ghost" id="btn-back" type="button" disabled>← Anterior</button>
            <button class="btn-primary-lg" id="btn-next" type="button" disabled>
              <span id="btn-next-label">Continuar</span>
              <Icon name="lucide:arrow-right" width={16} height={16} aria-hidden="true" />
            </button>
          </div>
        </div>

        <!-- Live summary -->
        <aside class="quote-summary" id="quote-summary">
          <div class="quote-summary__head">
            <h3 class="quote-summary__title">Tu cotización</h3>
            <p class="quote-summary__sub">Resumen en vivo</p>
          </div>
          <div class="quote-summary__body">
            <div class="quote-summary__row">
              <span class="k">Modalidad</span>
              <span class="v empty" id="sum-mode">Por definir</span>
            </div>
            <div class="quote-summary__row">
              <span class="k">Origen</span>
              <span class="v empty" id="sum-origin">Por definir</span>
            </div>
            <div class="quote-summary__row">
              <span class="k">Destino</span>
              <span class="v" id="sum-dest">{QUOTE_DESTS[0]}</span>
            </div>
            <div class="quote-summary__row">
              <span class="k">Incoterm</span>
              <span class="v" id="sum-incoterm">FOB</span>
            </div>
            <div class="quote-summary__row">
              <span class="k">Carga</span>
              <span class="v empty" id="sum-cargo">Por definir</span>
            </div>
            <div class="quote-summary__row">
              <span class="k">Volumen</span>
              <span class="v empty" id="sum-volume">Por definir</span>
            </div>
            <div class="quote-summary__row" id="sum-extras-row" hidden>
              <span class="k">Extras</span>
              <span class="v" id="sum-extras"></span>
            </div>
          </div>
          <div class="quote-summary__foot">
            <div class="quote-summary__sla">Respuesta garantizada en &lt; 24h hábiles</div>
          </div>
        </aside>

        <!-- Success state -->
        <div class="quote-card" id="quote-success" style="grid-column: 1 / -1;" hidden>
          <div class="quote-success">
            <div class="quote-success__seal" aria-hidden="true">✓</div>
            <h2 class="quote-success__title">Solicitud recibida</h2>
            <span class="quote-success__id" id="success-id">Folio · LA-—</span>
            <p class="quote-success__desc" id="success-desc">
              Gracias. Tu ejecutivo dedicado revisó la información
              y te contacta en menos de 24 horas hábiles.
            </p>
            <div class="quote-success__next">
              <div class="quote-success__step">
                <div class="quote-success__step-n">SIGUIENTE · 01</div>
                <h4 class="quote-success__step-t">Asignación</h4>
                <p class="quote-success__step-d">Te asignamos un ejecutivo según tu industria y ruta.</p>
              </div>
              <div class="quote-success__step">
                <div class="quote-success__step-n">SIGUIENTE · 02</div>
                <h4 class="quote-success__step-t">Propuesta</h4>
                <p class="quote-success__step-d">Recibes tarifa total desglosada y plazos por modalidad.</p>
              </div>
              <div class="quote-success__step">
                <div class="quote-success__step-n">SIGUIENTE · 03</div>
                <h4 class="quote-success__step-t">Ejecución</h4>
                <p class="quote-success__step-d">Aprobada la propuesta, coordinamos la operación.</p>
              </div>
            </div>
            <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
              <a class="btn btn--brand" href="/">Volver al inicio</a>
              <a class="btn btn--wa" href={SITE.whatsappUrl} target="_blank" rel="noopener noreferrer">
                <Icon name="lucide:message-circle" width={16} height={16} aria-hidden="true" />
                Hablar por WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  type Unit = 'cbm' | 'fcl20' | 'fcl40';

  const state = {
    step: 0,
    mode: '' as string,
    modeName: '' as string,
    origin: '',
    dest: '',
    incoterm: 'FOB',
    unit: 'cbm' as Unit,
    volume: '',
    weight: '',
    cargo: [] as string[],
    extras: [] as string[],
    name: '', company: '', email: '', phone: '', notes: '',
  };

  // Refs
  const $ = <T extends HTMLElement = HTMLElement>(sel: string) => document.querySelector(sel) as T | null;
  const $$ = <T extends HTMLElement = HTMLElement>(sel: string) => Array.from(document.querySelectorAll(sel)) as T[];

  const stepperSteps = $$<HTMLDivElement>('.stepper__step');
  const stepPanels   = $$<HTMLDivElement>('[data-step-panel]');
  const btnBack      = $('#btn-back') as HTMLButtonElement;
  const btnNext      = $('#btn-next') as HTMLButtonElement;
  const btnNextLabel = $('#btn-next-label');
  const stepperRoot  = $('#stepper');
  const quoteCard    = $('#quote-card');
  const summary      = $('#quote-summary');
  const success      = $('#quote-success');

  const sum = {
    mode:     $('#sum-mode'),
    origin:   $('#sum-origin'),
    dest:     $('#sum-dest'),
    incoterm: $('#sum-incoterm'),
    cargo:    $('#sum-cargo'),
    volume:   $('#sum-volume'),
    extras:   $('#sum-extras'),
    extrasRow:$('#sum-extras-row'),
  };

  // Initial defaults from selects
  const destSel     = $('#q-dest')     as HTMLSelectElement | null;
  const incotermSel = $('#q-incoterm') as HTMLSelectElement | null;
  if (destSel)     state.dest     = destSel.value || destSel.options[0]?.value || '';
  if (incotermSel) state.incoterm = incotermSel.value || 'FOB';

  function setText(el: Element | null, txt: string, empty = false) {
    if (!el) return;
    el.textContent = txt;
    el.classList.toggle('empty', empty);
  }

  function renderSummary() {
    setText(sum.mode,   state.modeName || 'Por definir', !state.modeName);
    setText(sum.origin, state.origin   || 'Por definir', !state.origin);
    setText(sum.dest,   state.dest, false);
    setText(sum.incoterm, state.incoterm, false);
    setText(sum.cargo,  state.cargo.length ? state.cargo.join(', ') : 'Por definir', state.cargo.length === 0);

    let vol = '';
    if (state.unit === 'cbm') {
      vol = state.volume ? `${state.volume} m³` : '';
    } else {
      const label = state.unit === 'fcl20' ? "20' FCL" : "40' FCL";
      vol = state.volume ? `${state.volume} × ${label}` : '';
    }
    setText(sum.volume, vol || 'Por definir', !vol);

    if (state.extras.length) {
      sum.extrasRow?.removeAttribute('hidden');
      setText(sum.extras, state.extras.join(', '), false);
    } else {
      sum.extrasRow?.setAttribute('hidden', '');
    }
  }

  function canAdvance(): boolean {
    if (state.step === 0) return !!state.mode;
    if (state.step === 1) return !!state.origin && !!state.dest;
    if (state.step === 2) return state.cargo.length > 0 && (!!state.volume || !!state.weight);
    if (state.step === 3) return !!state.name && !!state.email;
    return true;
  }

  function renderStep() {
    stepperSteps.forEach((el, i) => {
      el.classList.toggle('stepper__step--active', i === state.step);
      el.classList.toggle('stepper__step--done',   i <  state.step);
      const bullet = el.querySelector('.stepper__bullet');
      if (bullet) bullet.textContent = (i < state.step) ? '✓' : String(i + 1).padStart(2, '0');
    });
    stepPanels.forEach((p, i) => {
      if (i === state.step) p.removeAttribute('hidden');
      else                  p.setAttribute('hidden', '');
    });
    if (btnBack)      btnBack.disabled = state.step === 0;
    if (btnNext)      btnNext.disabled = !canAdvance();
    if (btnNextLabel) btnNextLabel.textContent = state.step === 3 ? 'Enviar solicitud' : 'Continuar';
  }

  // ── Step 0: mode tiles ────────────────────────────────────
  $$<HTMLButtonElement>('.mode-tile').forEach((btn) => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.mode || '';
      const name = btn.dataset.modeName || '';
      state.mode = mode;
      state.modeName = name;
      $$<HTMLButtonElement>('.mode-tile').forEach((b) => b.classList.toggle('mode-tile--active', b === btn));
      renderSummary();
      renderStep();
    });
  });

  // ── Step 1: route + incoterm + date ────────────────────────
  $('#q-origin')?.addEventListener('change',   (e) => { state.origin   = (e.target as HTMLSelectElement).value; renderSummary(); renderStep(); });
  $('#q-dest')?.addEventListener('change',     (e) => { state.dest     = (e.target as HTMLSelectElement).value; renderSummary(); renderStep(); });
  $('#q-incoterm')?.addEventListener('change', (e) => { state.incoterm = (e.target as HTMLSelectElement).value; renderSummary(); });

  // ── Step 2: cargo chips + unit toggle + volume fields ──────
  $$<HTMLButtonElement>('#cargo-chips .chip-multi').forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.cargo || '';
      const idx = state.cargo.indexOf(v);
      if (idx >= 0) state.cargo.splice(idx, 1);
      else          state.cargo.push(v);
      btn.classList.toggle('chip-multi--active');
      renderSummary();
      renderStep();
    });
  });

  $$<HTMLButtonElement>('#extras-chips .chip-multi').forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.extra || '';
      const idx = state.extras.indexOf(v);
      if (idx >= 0) state.extras.splice(idx, 1);
      else          state.extras.push(v);
      btn.classList.toggle('chip-multi--active');
      renderSummary();
    });
  });

  const cbmFields = $('#cbm-fields');
  const fclFields = $('#fcl-fields');
  $$<HTMLButtonElement>('#unit-toggle .unit-toggle__btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const u = (btn.dataset.unit || 'cbm') as Unit;
      state.unit   = u;
      state.volume = '';
      state.weight = '';
      $$<HTMLButtonElement>('#unit-toggle .unit-toggle__btn').forEach((b) => b.classList.toggle('unit-toggle__btn--active', b === btn));
      // Reset inputs
      (['q-volume', 'q-weight', 'q-count'] as const).forEach((id) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el) el.value = '';
      });
      if (u === 'cbm') {
        cbmFields?.removeAttribute('hidden');
        fclFields?.setAttribute('hidden', '');
      } else {
        cbmFields?.setAttribute('hidden', '');
        fclFields?.removeAttribute('hidden');
      }
      renderSummary();
      renderStep();
    });
  });

  $('#q-volume')?.addEventListener('input', (e) => { state.volume = (e.target as HTMLInputElement).value; renderSummary(); renderStep(); });
  $('#q-weight')?.addEventListener('input', (e) => { state.weight = (e.target as HTMLInputElement).value; renderSummary(); renderStep(); });
  $('#q-count')?.addEventListener('input',  (e) => { state.volume = (e.target as HTMLInputElement).value; renderSummary(); renderStep(); });

  // ── Step 3: contact ────────────────────────────────────────
  $('#q-name')?.addEventListener('input',    (e) => { state.name    = (e.target as HTMLInputElement).value; renderStep(); });
  $('#q-company')?.addEventListener('input', (e) => { state.company = (e.target as HTMLInputElement).value; });
  $('#q-email')?.addEventListener('input',   (e) => { state.email   = (e.target as HTMLInputElement).value; renderStep(); });
  $('#q-phone')?.addEventListener('input',   (e) => { state.phone   = (e.target as HTMLInputElement).value; });
  $('#q-notes')?.addEventListener('input',   (e) => { state.notes   = (e.target as HTMLInputElement).value; });

  // ── Navigation ─────────────────────────────────────────────
  btnBack?.addEventListener('click', () => {
    if (state.step > 0) {
      state.step -= 1;
      renderStep();
    }
  });

  btnNext?.addEventListener('click', () => {
    if (!canAdvance()) return;
    if (state.step < 3) {
      state.step += 1;
      renderStep();
    } else {
      showSuccess();
    }
  });

  // Allow clicking a stepper bullet to jump back to a completed step
  stepperSteps.forEach((el, i) => {
    el.addEventListener('click', () => {
      if (i <= state.step) {
        state.step = i;
        renderStep();
      }
    });
  });

  function showSuccess() {
    const id = 'LA-' + String(Date.now()).slice(-6);
    const idEl   = $('#success-id');
    const descEl = $('#success-desc');
    if (idEl)   idEl.textContent = `Folio · ${id}`;
    const firstName = state.name.split(' ')[0] || '';
    if (descEl) descEl.textContent =
      `Gracias ${firstName}. Tu ejecutivo dedicado revisó la información y te contacta en menos de 24 horas hábiles al correo ${state.email}.`;
    stepperRoot?.setAttribute('hidden', '');
    quoteCard?.setAttribute('hidden', '');
    summary?.setAttribute('hidden', '');
    success?.removeAttribute('hidden');
    success?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Initial render
  renderSummary();
  renderStep();
</script>
