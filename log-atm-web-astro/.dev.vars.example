# SMTP — completar con credenciales reales de ioh.
# Copiar este archivo a `.dev.vars` (no comiteado) antes de levantar `astro dev`.
# En Cloudflare Pages productivo, estas variables se configuran en el dashboard.
SMTP_HOST=mail.logatm.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=web@logatm.com
SMTP_PASS=
MAIL_TO=contacto@logatm.com

# Para QA sin SMTP real, usar Ethereal Email (https://ethereal.email/create)
# Genera credenciales gratuitas que capturan el correo sin enviarlo realmente.
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=<generado por Ethereal>
# SMTP_PASS=<generado por Ethereal>
